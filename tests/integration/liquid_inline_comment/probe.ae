// contrib.templating.liquid — `{%# inline comment %}` form.
//
// Shopify's single-tag comment: drops the tag without needing an
// `{% endcomment %}`. Lex-time skip.
//
// Cases:
//   1. Bare inline comment alone
//   2. Inline comment between text
//   3. Inline comment between text + variable
//   4. Multi-line inline comment (until closing %})
//   5. Whitespace control: `{%#- ... -%}` strips around it
//   6. Inline comment inside a `{% liquid %}` block? No — `{% liquid %}`
//      uses `#` at line start; this slice is about the bracketed form

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

main() {
    // (1) Bare inline comment.
    expect_eq(render_empty("{%# hidden %}"), "", "1 bare inline comment")

    // (2) Inline comment between text.
    expect_eq(render_empty("hi{%# secret %}there"), "hithere", "2 between text")

    // (3) Inline comment + variable.
    t3, _ = liquid.parse_string("{%# author %}Hi {{ name }}!")
    ctx3 = liquid.context_new()
    liquid.context_put_string(ctx3, "name", "alice")
    out3, _ = liquid.render(t3, ctx3)
    expect_eq(out3, "Hi alice!", "3 inline comment + var")

    // (4) Multi-line inline comment.
    expect_eq(render_empty("a{%# this\nspans\nmany\nlines %}b"),
              "ab", "4 multi-line inline comment")

    // (5) Whitespace control around inline comment.
    //   The dash sits BEFORE the `#` (the leading dash is the WS
    //   modifier on `{%`, and the `#` is what marks this as an inline
    //   comment): `{%-# ... -%}`.
    expect_eq(render_empty("a   {%-# gone -%}   b"),
              "ab", "5 ws-control inline comment")

    // (6) Pre-existing `{% comment %}` block form still works.
    expect_eq(render_empty("a{% comment %}old form{% endcomment %}b"),
              "ab", "6 block comment unaffected")

    println("All PASS")
}
