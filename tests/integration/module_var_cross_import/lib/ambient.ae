// An imported module providing an ambient/process-global cell via #701
// module-level `var` — set by one fn, mutated by another, read by a third.
exports ( init, bump, current, scratch )
var cur = 0
init(v: int) { cur = v }
bump() { cur = cur + 1 }
current() -> int { return cur }
// scratch() uses a genuine LOCAL `tmp` (must stay local) alongside a write
// to the global `cur` (must reach the shared global) — guards against the
// fix over-reaching and rewriting real locals.
scratch(n: int) -> int {
    tmp = n * 10
    cur = tmp
    return tmp + cur
}
