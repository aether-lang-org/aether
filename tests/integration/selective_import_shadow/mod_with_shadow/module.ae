// Reproduces the issue #436 facet A footgun: this module selectively
// imports `length` AND defines a local `length(...)` with the same
// name. Pre-fix, the merger renamed `length(s)` in the body to
// `mod_with_shadow_length(s)` — the body became infinite self-
// recursion. Post-fix, the orchestrator rejects this module with a
// precise diagnostic naming both the import and the local def.
import std.string (length)

length(s: string) -> int {
    return length(s)
}

exports (length)
