// Origin server for the forward-proxy regression (aether#1012 part 2).
// Returns "ORIGIN-BODY" on GET /. Started by the .sh driver.

import std.http

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18120

handle_root(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_body(res, "ORIGIN-BODY")
}

message StartSrv { raw: ptr }
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}

main() {
    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 { println("FAIL: server_create null") exit(1) }
    http.server_get(raw, "/", handle_root, 0)
    println("READY")
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }
    sleep(60000)
    exit(0)
}
