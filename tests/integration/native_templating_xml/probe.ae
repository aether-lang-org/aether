// contrib.templating.native — XML emitter (skinny v1) smoke test.
//
// What this exercises:
//   1. render_xml() prefixes the standard XML 1.0/UTF-8 prolog.
//   2. xml_tag() open/close around the trailing block, escape-correct.
//   3. xml_self_close() emits <name/>.
//   4. xml_text() escapes XML's five entities (note: ' → &apos;,
//      NOT &#39; like HTML).
//   5. xml_raw() bypasses escaping (CDATA, vetted markup).
//   6. for-loop inside xml_tag composes — real Aether control flow.
//   7. Aether ${...} interpolation flows through xml_text() with
//      XML-correct escapes.
//
// Note: v1 intentionally has NO attribute helper. Attribute-shaped
// data must lift into child elements or use xml_raw against a tag
// built by hand. Re-debate when a real user surfaces.

import contrib.templating.native
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}:")
        println("  got:  '${actual}'")
        println("  want: '${want}'")
        exit(1)
    }
    println("PASS ${label}")
}

main() {
    prolog = "<?xml version=\"1.0\" encoding=\"UTF-8\"?>"

    // (1) Prolog + empty block.
    out1 = native.render_xml() { }
    expect_eq(out1, prolog, "1 prolog only")

    // (2) Basic tag wrap.
    out2 = native.render_xml() {
        native.xml_tag("greeting") { native.xml_text("hi") }
    }
    expect_eq(out2, "${prolog}<greeting>hi</greeting>", "2 basic tag wrap")

    // (3) Self-closing element.
    out3 = native.render_xml() {
        native.xml_self_close("empty")
    }
    expect_eq(out3, "${prolog}<empty/>", "3 self-close")

    // (4) XML escape — NB. ' escapes to &apos; not &#39;.
    out4 = native.render_xml() {
        native.xml_tag("q") { native.xml_text("<x>&y\"z'") }
    }
    expect_eq(out4, "${prolog}<q>&lt;x&gt;&amp;y&quot;z&apos;</q>", "4 xml_text escapes")

    // (5) xml_raw bypasses escaping (e.g. for CDATA).
    out5 = native.render_xml() {
        native.xml_tag("doc") {
            native.xml_raw("<![CDATA[ <not escaped> ]]>")
        }
    }
    expect_eq(out5, "${prolog}<doc><![CDATA[ <not escaped> ]]></doc>", "5 xml_raw bypasses")

    // (6) For loop inside xml_tag — same pitch as the HTML side:
    //     Aether's own `for`, not a template-language reimplementation.
    titles = ["First", "Second", "Third & last"]
    out6 = native.render_xml() {
        native.xml_tag("channel") {
            for i in 0..3 {
                native.xml_tag("item") {
                    native.xml_tag("title") { native.xml_text(titles[i]) }
                }
            }
        }
    }
    expect_eq(out6,
              "${prolog}<channel><item><title>First</title></item><item><title>Second</title></item><item><title>Third &amp; last</title></item></channel>",
              "6 for loop inside xml_tag")

    // (7) ${...} interpolation flows through xml_text with XML escape.
    user_input = "<script>alert('xss')</script>"
    out7 = native.render_xml() {
        native.xml_tag("comment") { native.xml_text("user said: ${user_input}") }
    }
    expect_eq(out7,
              "${prolog}<comment>user said: &lt;script&gt;alert(&apos;xss&apos;)&lt;/script&gt;</comment>",
              "7 interp escapes captured user value")

    println("All PASS")
}
