// Validate std.cryptography.sha3 against FIPS 202 / NIST known-answer
// vectors: SHA3-224/256/384/512 fixed-length digests and the SHAKE128/256
// extendable-output functions.
import std.cryptography.sha3
import std.io

check(label: string, got: string, want: string) -> int {
    if got == want {
        println("ok   ${label}")
        return 0
    }
    println("FAIL ${label}")
    println("  got:  ${got}")
    println("  want: ${want}")
    return 1
}

main() {
    fails = 0

    fails = fails + check("sha3-256 empty",
        sha3.sha3_256_hex("", 0),
        "a7ffc6f8bf1ed76651c14756a061d662f580ff4de43b49fa82d80a4b80f8434a")
    fails = fails + check("sha3-256 abc",
        sha3.sha3_256_hex("abc", 3),
        "3a985da74fe225b2045c172d6bd390bd855f086e3e9d525b46bfe24511431532")
    fails = fails + check("sha3-224 empty",
        sha3.sha3_224_hex("", 0),
        "6b4e03423667dbb73b6e15454f0eb1abd4597f9a1b078e3f5b5a6bc7")
    fails = fails + check("sha3-384 empty",
        sha3.sha3_384_hex("", 0),
        "0c63a75b845e4f7d01107d852e4c2485c51a50aaaa94fc61995e71bbee983a2ac3713831264adb47fb6bd1e058d5f004")
    fails = fails + check("sha3-512 empty",
        sha3.sha3_512_hex("", 0),
        "a69f73cca23a9ac5c8b567dc185a756e97c982164fe25859e0d1dcc1475c80a615b2123af1f5f94c11e3e9402c3ac558f500199d95b6d3e301758586281dcd26")

    // SHAKE XOF — caller-specified output length.
    fails = fails + check("shake128 empty/16",
        sha3.shake128_hex("", 0, 16),
        "7f9c2ba4e88f827d616045507605853e")
    fails = fails + check("shake256 empty/32",
        sha3.shake256_hex("", 0, 32),
        "46b9dd2b0ba88d13233b3feb743eeb243fcd52ea62b81b82b50c27646ed5762f")
    fails = fails + check("shake128 abc/32",
        sha3.shake128_hex("abc", 3, 32),
        "5881092dd818bf5cf8a3ddb793fbcba74097d5c526a6d35f97b83351940f2cc8")

    if fails == 0 {
        println("ALL PASS")
        return
    }
    println("FAILURES")
    exit(1)
}
