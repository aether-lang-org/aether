// contrib.templating.liquid — `{% tablerow %}` HTML-table iterator.
//
// Shopify wraps each iteration in `<td class="colN">` and breaks into
// a new `<tr class="rowM">` after `cols` items. Without `cols`, all
// items go in one row. `forloop.*` exposed; `limit`/`offset`/`reversed`
// modifiers same as `for`. Range form only (matches `for`).
//
// Cases:
//   1.  Basic 3-item tablerow, no cols -> single row
//   2.  cols:2 over 4 items -> two rows of 2
//   3.  cols:2 over 3 items -> row1=2 items, row2=1 item
//   4.  Empty range still emits an <tr class="row1"></tr>
//   5.  Body interpolates the loop var
//   6.  forloop.first / forloop.last visible inside body
//   7.  limit + cols
//   8.  offset + cols
//   9.  reversed + cols
//   10. Range bounds from variables
//   11. Loop var restored after the block
//   12. Non-range iterable -> clear error
//   13. Unmatched tablerow -> error
//   14. Stray endtablerow -> error

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

render_with(src: string, key: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, key, val)
    out, _ = liquid.render(t, ctx)
    return out
}

main() {
    // (1) Basic single-row.
    expect_eq(render_empty("{% tablerow i in (1..3) %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">1</td><td class=\"col2\">2</td><td class=\"col3\">3</td></tr>\n",
              "1 basic single row")

    // (2) cols:2 over 4.
    expect_eq(render_empty("{% tablerow i in (1..4) cols:2 %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">1</td><td class=\"col2\">2</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">3</td><td class=\"col2\">4</td></tr>\n",
              "2 cols:2 over 4")

    // (3) cols:2 over 3 -> uneven last row.
    expect_eq(render_empty("{% tablerow i in (1..3) cols:2 %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">1</td><td class=\"col2\">2</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">3</td></tr>\n",
              "3 uneven last row")

    // (4) Empty range still emits row1.
    expect_eq(render_empty("{% tablerow i in (5..1) %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n</tr>\n",
              "4 empty range emits row1")

    // (5) Body interpolates.
    expect_eq(render_empty("{% tablerow i in (1..2) %}[{{ i }}]{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">[1]</td><td class=\"col2\">[2]</td></tr>\n",
              "5 body interpolates")

    // (6) forloop.first / forloop.last visible.
    expect_eq(render_empty("{% tablerow i in (1..3) %}{{ forloop.first }}/{{ forloop.last }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">true/false</td><td class=\"col2\">false/false</td><td class=\"col3\">false/true</td></tr>\n",
              "6 forloop.first/last")

    // (7) limit + cols.
    expect_eq(render_empty("{% tablerow i in (1..10) limit:3 cols:2 %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">1</td><td class=\"col2\">2</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">3</td></tr>\n",
              "7 limit+cols")

    // (8) offset + cols.
    expect_eq(render_empty("{% tablerow i in (1..5) offset:2 cols:2 %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">3</td><td class=\"col2\">4</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">5</td></tr>\n",
              "8 offset+cols")

    // (9) reversed + cols.
    expect_eq(render_empty("{% tablerow i in (1..3) reversed cols:2 %}{{ i }}{% endtablerow %}"),
              "<tr class=\"row1\">\n<td class=\"col1\">3</td><td class=\"col2\">2</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">1</td></tr>\n",
              "9 reversed+cols")

    // (10) LO/HI from variables.
    t10, _ = liquid.parse_string("{% tablerow i in (lo..hi) cols:2 %}{{ i }}{% endtablerow %}")
    ctx10 = liquid.context_new()
    liquid.context_put_string(ctx10, "lo", "10")
    liquid.context_put_string(ctx10, "hi", "12")
    out10, _ = liquid.render(t10, ctx10)
    expect_eq(out10,
              "<tr class=\"row1\">\n<td class=\"col1\">10</td><td class=\"col2\">11</td></tr>\n<tr class=\"row2\">\n<td class=\"col1\">12</td></tr>\n",
              "10 vars as bounds")

    // (11) Loop var restored.
    expect_eq(render_with("[{{ i }}]{% tablerow i in (1..2) %}{{ i }}{% endtablerow %}[{{ i }}]",
                          "i", "PRE"),
              "[PRE]<tr class=\"row1\">\n<td class=\"col1\">1</td><td class=\"col2\">2</td></tr>\n[PRE]",
              "11 var restored")

    // (12) Non-range iterable.
    t12, _ = liquid.parse_string("{% tablerow x in mylist %}{{ x }}{% endtablerow %}")
    _, e12 = liquid.render(t12, liquid.context_new())
    if string.equals(e12, "") == 1 {
        println("FAIL 12 non-range iterable: expected error")
        exit(1)
    }
    println("PASS 12 non-range iterable: '${e12}'")

    // (13) Unmatched tablerow.
    t13, _ = liquid.parse_string("{% tablerow i in (1..3) %}body never closed")
    _, e13 = liquid.render(t13, liquid.context_new())
    if string.equals(e13, "") == 1 {
        println("FAIL 13 unmatched: expected error")
        exit(1)
    }
    println("PASS 13 unmatched tablerow: '${e13}'")

    // (14) Stray endtablerow.
    t14, _ = liquid.parse_string("hi {% endtablerow %}")
    _, e14 = liquid.render(t14, liquid.context_new())
    if string.equals(e14, "") == 1 {
        println("FAIL 14 stray: expected error")
        exit(1)
    }
    println("PASS 14 stray endtablerow: '${e14}'")

    println("All PASS")
}
