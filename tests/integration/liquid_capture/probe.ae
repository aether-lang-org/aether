// contrib.templating.liquid — `{% capture NAME %}…{% endcapture %}` tag.
//
// `capture` renders its body (including nested {{ }} and tags) into a
// string and binds it under NAME. The renderer skips the body's normal
// emission — the captured string is written to the context, not to the
// outer output buffer.
//
// Cases:
//   1.  Bare capture: body is plain text
//   2.  Capture interpolates {{ var }} from the surrounding context
//   3.  Capture body includes a filter chain
//   4.  Capture body itself contains an `{% assign %}` (visible after
//       the capture closes — assignments leak to the parent ctx; this
//       matches Shopify semantics)
//   5.  Two captures in a row, second uses the first
//   6.  Captured name shadows an outer same-named binding
//   7.  Nested capture: inner runs first, outer references it
//   8.  Capture inside `{% comment %}` is dropped (comment wins,
//       capture never runs)
//   9.  Body emits nothing (empty between tags)
//   10. Missing name → render error
//   11. Unmatched `{% capture %}` → render error
//   12. Stray `{% endcapture %}` without a matching capture → render error
//   13. Whitespace control on the capture opener/closer trims correctly
//       around the captured text

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

main() {
    // (1) Bare capture of literal text.
    t1, _ = liquid.parse_string("{% capture msg %}hello{% endcapture %}>{{ msg }}<")
    out1, _ = liquid.render(t1, liquid.context_new())
    expect_eq(out1, ">hello<", "1 bare capture")

    // (2) Capture interpolates from surrounding ctx.
    t2, _ = liquid.parse_string("{% capture greet %}Hi {{ name }}{% endcapture %}>>{{ greet }}<<")
    ctx2 = liquid.context_new()
    liquid.context_put_string(ctx2, "name", "alice")
    out2, _ = liquid.render(t2, ctx2)
    expect_eq(out2, ">>Hi alice<<", "2 capture interpolates var")

    // (3) Capture body uses a filter chain.
    t3, _ = liquid.parse_string("{% capture loud %}{{ name | upcase | append:\"!\" }}{% endcapture %}{{ loud }}")
    ctx3 = liquid.context_new()
    liquid.context_put_string(ctx3, "name", "alice")
    out3, _ = liquid.render(t3, ctx3)
    expect_eq(out3, "ALICE!", "3 capture body uses filters")

    // (4) Capture body contains `{% assign %}` — assignment leaks to
    //     parent context (Shopify semantics — variables are global).
    t4, _ = liquid.parse_string("{% capture _ %}{% assign x = \"set\" %}{% endcapture %}{{ x }}")
    out4, _ = liquid.render(t4, liquid.context_new())
    expect_eq(out4, "set", "4 capture-internal assign leaks")

    // (5) Second capture references the first.
    t5, _ = liquid.parse_string("{% capture a %}AA{% endcapture %}{% capture b %}{{ a }}-BB{% endcapture %}{{ b }}")
    out5, _ = liquid.render(t5, liquid.context_new())
    expect_eq(out5, "AA-BB", "5 second capture uses first")

    // (6) Captured name shadows an outer binding.
    t6, _ = liquid.parse_string("[{{ x }}]{% capture x %}NEW{% endcapture %}[{{ x }}]")
    ctx6 = liquid.context_new()
    liquid.context_put_string(ctx6, "x", "OLD")
    out6, _ = liquid.render(t6, ctx6)
    expect_eq(out6, "[OLD][NEW]", "6 capture shadows ctx")

    // (7) Nested capture — inner binds first, outer references it.
    t7, _ = liquid.parse_string("{% capture outer %}({% capture inner %}IN{% endcapture %}{{ inner }}){% endcapture %}[{{ outer }}][{{ inner }}]")
    out7, _ = liquid.render(t7, liquid.context_new())
    expect_eq(out7, "[(IN)][IN]", "7 nested captures")

    // (8) Capture inside `{% comment %}` is dropped.
    t8, _ = liquid.parse_string("a{% comment %}{% capture m %}never{% endcapture %}{% endcomment %}b<{{ m }}>")
    out8, _ = liquid.render(t8, liquid.context_new())
    expect_eq(out8, "ab<>", "8 capture under comment dropped")

    // (9) Empty body.
    t9, _ = liquid.parse_string("{% capture m %}{% endcapture %}[{{ m }}]")
    out9, _ = liquid.render(t9, liquid.context_new())
    expect_eq(out9, "[]", "9 empty capture body")

    // (10) Missing name.
    t10, _ = liquid.parse_string("{% capture %}body{% endcapture %}")
    _, e10 = liquid.render(t10, liquid.context_new())
    if string.equals(e10, "") == 1 {
        println("FAIL 10 missing name: expected error")
        exit(1)
    }
    println("PASS 10 missing name: '${e10}'")

    // (11) Unmatched capture.
    t11, _ = liquid.parse_string("before {% capture m %}body never closed")
    _, e11 = liquid.render(t11, liquid.context_new())
    if string.equals(e11, "") == 1 {
        println("FAIL 11 unmatched capture: expected error")
        exit(1)
    }
    println("PASS 11 unmatched capture: '${e11}'")

    // (12) Stray endcapture.
    t12, _ = liquid.parse_string("hi {% endcapture %} bye")
    _, e12 = liquid.render(t12, liquid.context_new())
    if string.equals(e12, "") == 1 {
        println("FAIL 12 stray endcapture: expected error")
        exit(1)
    }
    println("PASS 12 stray endcapture: '${e12}'")

    // (13) Whitespace control around capture.
    t13, _ = liquid.parse_string("a   {%- capture m -%}   body   {%- endcapture -%}   b{{ m }}")
    out13, _ = liquid.render(t13, liquid.context_new())
    expect_eq(out13, "abbody", "13 whitespace control around capture")

    println("All PASS")
}
