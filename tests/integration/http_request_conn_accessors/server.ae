// http.request_remote_port / local_addr / local_port / scheme /
// is_tls / http_version — connection-level accessors that complement
// remote_addr. Echoes every field as a pipe-separated string so the
// shell runner can assert each independently.

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18294

handle_whoami(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    peer = http.request_remote_addr(req)
    peer_port = http.request_remote_port(req)
    local = http.request_local_addr(req)
    local_port = http.request_local_port(req)
    scheme = http.request_scheme(req)
    is_tls = http.request_is_tls(req)
    ver = http.request_http_version(req)
    peer_port_nonzero = 0
    if peer_port > 0 { peer_port_nonzero = 1 }
    http.response_set_body(res,
        "peer=${peer}|peer_port_nz=${peer_port_nonzero}|local=${local}|local_port=${local_port}|scheme=${scheme}|is_tls=${is_tls}|ver=${ver}")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    println("READY")

    http.server_get(raw, "/whoami", handle_whoami, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}
