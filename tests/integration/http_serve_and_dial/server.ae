// Serve-and-dial: an HTTP server request handler makes an outbound HTTP
// client call *while handling an inbound request*, and the inner response
// body round-trips out through the outer response.
//
// Topology (all in one process, mirrors an aeo middle agent):
//   D (server, :18582) -> GET /leaf returns "D-BODY"
//   C (server, :18581) -> GET /x handler dials D:/leaf and returns its body
//   main               -> GET C:/x, expects "...D-BODY..."
//
// This exercises two things at once:
//   1. serve-and-dial is possible when servers start NON-BLOCKING
//      (http_server_start_background_raw), so one process hosts both.
//   2. concurrent name resolution across threads is safe — the inner dial
//      runs on a server worker thread while main's dial runs on the main
//      thread. A regression to gethostbyname (shared static hostent) would
//      corrupt one call's resolved address and this test would fail.
//
// It also documents the correct client-response lifetime: response_body()
// returns a BORROWED pointer into the response, so the body must be consumed
// (copied / interpolated / matched) BEFORE response_free() is called.

import std.http.client
import std.http
import std.string

extern exit(code: int)
// Non-blocking start. Present in the C runtime + aether_http_server.h but not
// yet re-exported through std/net/module.ae, so declare it directly here.
extern http_server_start_background_raw(server: ptr) -> int

const PORT_C = 18581
const PORT_D = 18582

handle_leaf(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_body(res, "D-BODY")
}

handle_x(req: ptr, res: ptr, ud: ptr) {
    rq = client.request("GET", "http://127.0.0.1:${PORT_D}/leaf")
    client.set_timeout(rq, 5s)
    resp, err = client.send_request(rq)
    client.request_free(rq)
    if err != "" {
        http.response_set_status(res, 502)
        http.response_set_body(res, "DIAL-ERR: ${err}")
        return
    }
    // Consume the borrowed body BEFORE freeing the response.
    body = client.response_body(resp)
    st = client.response_status(resp)
    http.response_set_status(res, 200)
    http.response_set_body(res, "inner-status=${st} inner-body=${body}")
    client.response_free(resp)
}

main() {
    d = http.server_create(PORT_D)
    http.server_set_host(d, "127.0.0.1")
    http.server_get(d, "/leaf", handle_leaf, 0)

    c = http.server_create(PORT_C)
    http.server_set_host(c, "127.0.0.1")
    http.server_get(c, "/x", handle_x, 0)

    if d == 0 || c == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    // Non-blocking: both return immediately and listen on detached threads.
    http_server_start_background_raw(d)
    http_server_start_background_raw(c)
    sleep(500)

    rq = client.request("GET", "http://127.0.0.1:${PORT_C}/x")
    client.set_timeout(rq, 8s)
    resp, err = client.send_request(rq)
    if err != "" {
        println("FAIL: outer send_request: ${err}")
        client.request_free(rq)
        exit(2)
    }
    body = client.response_body(resp)
    st = client.response_status(resp)
    matched = string.contains(body, "D-BODY")
    println("outer-status=${st}")
    println("outer-body=${body}")
    client.response_free(resp)
    client.request_free(rq)

    if st == 200 && matched == 1 {
        println("SERVE_AND_DIAL_OK")
        exit(0)
    }
    println("FAIL: serve-and-dial body did not round-trip")
    exit(3)
}
