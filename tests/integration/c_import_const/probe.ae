// #702 — import object-like C macros as typed constants.
//
// `extern const NAME: type @c_import` teaches the typechecker a name and
// an Aether type; the generated C emits the macro name VERBATIM at every
// use site and emits nothing for the declaration itself (no value, no
// forward decl). The including TU's headers are the source of truth, so
// per-platform values come out right by construction.
//
// This probe imports three macros from consts.h (force-included via
// aether.toml) plus EOF from <stdio.h> (always included by the runtime
// prelude), uses them in comparison / call contexts, and asserts.

extern const MY_FLAG: int @c_import      // = 7   (header)
extern const MY_LIMIT: int @c_import     // = 1000 (header)
extern const MY_BUILD: ptr @c_import     // = "aether-702" (string macro)
extern const EOF: int @c_import          // = -1  (stdio.h)

extern puts(s: ptr) -> int
extern exit(code: int)

// The macro is usable in an ordinary expression/comparison context.
under_limit(n: int) -> bool {
    return n < MY_LIMIT
}

main() {
    if MY_FLAG != 7 {
        print("FAIL: MY_FLAG\n")
        exit(1)
    }
    if EOF != -1 {
        print("FAIL: EOF\n")
        exit(1)
    }
    if under_limit(999) == false {
        print("FAIL: MY_LIMIT comparison\n")
        exit(1)
    }
    if under_limit(1000) == true {
        print("FAIL: MY_LIMIT boundary\n")
        exit(1)
    }

    // String macro round-trips through C verbatim.
    puts(MY_BUILD)
    print("PASS\n")
}
