// contrib.templating.liquid — `{% extends 'parent' %}` alias for
// `{% layout %}`, and `{{ block.super }}` inside child block overrides.
//
// `{% extends %}` is the Django/Jinja spelling; behaviour is identical to
// `{% layout %}`. `{{ block.super }}` inside a child's override emits the
// parent's default block content; outside an override it expands to "".
//
// Cases:
//   1.  `{% extends 'parent' %}` works as an alias of `{% layout %}`
//   2.  `{% extends %}` + multiple blocks
//   3.  `{% extends %}` missing parent name -> error (same as layout)
//   4.  `{{ block.super }}` emits parent default
//   5.  `{{ block.super }}` plus extra child content concatenates
//   6.  `{{ block.super }}` used twice in the same override
//   7.  `{{ block.super }}` with no surrounding block -> "" (no error)
//   8.  Two different blocks each call `{{ block.super }}` correctly
//   9.  `{{ block.super }}` inside a filter chain (upcase)
//   10. `{{ block.super }}` after a `{% block %}` that fell through to
//       parent default -> still "" (no super context leaked)

import contrib.templating.liquid
import std.string
import std.os

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

main() {
    root = os.getenv("LIQUID_PARTIAL_ROOT")
    if string_length(root) == 0 {
        println("FAIL setup: LIQUID_PARTIAL_ROOT not set")
        exit(1)
    }

    // (1) extends alias — single block override.
    src1 = "{% extends 'wrap' %}\n{% block body %}HI{% endblock %}"
    t1, _ = liquid.parse_string(src1)
    ctx1 = liquid.context_new()
    liquid.context_set_include_root(ctx1, root)
    out1, _ = liquid.render(t1, ctx1)
    expect_eq(out1, "<wrap>HI</wrap>\n", "1 extends alias single block")

    // (2) extends + multiple blocks.
    src2 = "{% extends 'base' %}{% block title %}T{% endblock %}{% block content %}C{% endblock %}"
    t2, _ = liquid.parse_string(src2)
    ctx2 = liquid.context_new()
    liquid.context_set_include_root(ctx2, root)
    out2, _ = liquid.render(t2, ctx2)
    expect_eq(out2,
              "<html>\n<head><title>T</title></head>\n<body>\nC\n</body>\n</html>\n",
              "2 extends multiple blocks")

    // (3) extends missing parent name -> error.
    src3 = "{% extends %}"
    t3, _ = liquid.parse_string(src3)
    ctx3 = liquid.context_new()
    liquid.context_set_include_root(ctx3, root)
    _, err3 = liquid.render(t3, ctx3)
    if string.equals(err3, "") == 1 {
        println("FAIL 3 extends missing name: expected error")
        exit(1)
    }
    println("PASS 3 extends missing name: '${err3}'")

    // (4) block.super emits parent default.
    src4 = "{% layout 'wrap' %}{% block body %}{{ block.super }}{% endblock %}"
    t4, _ = liquid.parse_string(src4)
    ctx4 = liquid.context_new()
    liquid.context_set_include_root(ctx4, root)
    out4, _ = liquid.render(t4, ctx4)
    expect_eq(out4, "<wrap>WRAP DEFAULT</wrap>\n", "4 block.super expands to parent default")

    // (5) block.super concatenated with extra child text.
    src5 = "{% layout 'wrap' %}{% block body %}{{ block.super }}/EXTRA{% endblock %}"
    t5, _ = liquid.parse_string(src5)
    ctx5 = liquid.context_new()
    liquid.context_set_include_root(ctx5, root)
    out5, _ = liquid.render(t5, ctx5)
    expect_eq(out5, "<wrap>WRAP DEFAULT/EXTRA</wrap>\n", "5 block.super + extra")

    // (6) block.super used twice.
    src6 = "{% layout 'wrap' %}{% block body %}{{ block.super }}|{{ block.super }}{% endblock %}"
    t6, _ = liquid.parse_string(src6)
    ctx6 = liquid.context_new()
    liquid.context_set_include_root(ctx6, root)
    out6, _ = liquid.render(t6, ctx6)
    expect_eq(out6, "<wrap>WRAP DEFAULT|WRAP DEFAULT</wrap>\n", "6 block.super twice")

    // (7) block.super outside any block -> "".
    src7 = "before {{ block.super }} after"
    t7, _ = liquid.parse_string(src7)
    ctx7 = liquid.context_new()
    out7, _ = liquid.render(t7, ctx7)
    expect_eq(out7, "before  after", "7 block.super outside override = empty")

    // (8) Two blocks each calling block.super independently.
    src8 = "{% layout 'base' %}{% block title %}{{ block.super }}-X{% endblock %}{% block content %}{{ block.super }}-Y{% endblock %}"
    t8, _ = liquid.parse_string(src8)
    ctx8 = liquid.context_new()
    liquid.context_set_include_root(ctx8, root)
    out8, _ = liquid.render(t8, ctx8)
    expect_eq(out8,
              "<html>\n<head><title>DEFAULT TITLE-X</title></head>\n<body>\nDEFAULT CONTENT-Y\n</body>\n</html>\n",
              "8 two blocks both call super")

    // (9) block.super through a filter.
    src9 = "{% layout 'wrap' %}{% block body %}{{ block.super | upcase }}{% endblock %}"
    t9, _ = liquid.parse_string(src9)
    ctx9 = liquid.context_new()
    liquid.context_set_include_root(ctx9, root)
    out9, _ = liquid.render(t9, ctx9)
    expect_eq(out9, "<wrap>WRAP DEFAULT</wrap>\n", "9 block.super | upcase")

    // (10) A block that fell through to parent default — a sibling
    // block's override sees "" for its own super reference no longer
    // (super state must reset between blocks).
    src10 = "{% layout 'base' %}{% block content %}{{ block.super }}{% endblock %}"
    t10, _ = liquid.parse_string(src10)
    ctx10 = liquid.context_new()
    liquid.context_set_include_root(ctx10, root)
    out10, _ = liquid.render(t10, ctx10)
    expect_eq(out10,
              "<html>\n<head><title>DEFAULT TITLE</title></head>\n<body>\nDEFAULT CONTENT\n</body>\n</html>\n",
              "10 super in one block, default fallthrough in other")

    println("All PASS")
}
