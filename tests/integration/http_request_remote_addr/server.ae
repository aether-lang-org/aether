// http.request_remote_addr — trusted TCP peer address, exposed to
// handlers via the new extern. Distinct from X-Forwarded-For (the
// header-based, client-supplied signal — middleware's job).
//
// Verifies, end to end:
//   - the handler sees the real socket peer (127.0.0.1 over localhost)
//   - a spoofed X-Forwarded-For does NOT influence remote_addr (the
//     accessor reads getpeername, not headers)

import std.http
import std.os

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18293

handle_whoami(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    real = http.request_remote_addr(req)
    spoofed = http.get_header(req, "X-Forwarded-For")
    if spoofed == null {
        spoofed = ""
    }
    http.response_set_body(res, "peer=${real}|xff=${spoofed}")
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    println("READY")

    http.server_get(raw, "/whoami", handle_whoami, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}
