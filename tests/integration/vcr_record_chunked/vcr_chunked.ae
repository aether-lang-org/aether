// VCR record mode against a `Transfer-Encoding: chunked` upstream
// (vcr_record_chunked_dechunk_wish.md). The upstream is a raw-socket C
// responder (chunked_upstream.c) on the port in $UPSTREAM_PORT — the
// Aether HTTP server can't emit chunked (it always sets Content-Length).
//
// Asserts the fix at both tiers:
//   1. std.http.client de-chunks a chunked response body.
//   2. VCR record mode stores the decoded payload (not chunk framing),
//      and replay serves the decoded body — the definitive check, since
//      framed bytes in the tape would replay framed and fail equality.

import std.http.server.vcr
import std.http.client
import std.http
import std.fs
import std.io
import std.string

extern exit(code: int)

const RECORD_PORT   = 18267
const PLAYBACK_PORT = 18268
const BODY          = "hello-from-upstream"

tape_path() -> {
    tmp = io.getenv("TMPDIR")
    if tmp == 0 { tmp = "/tmp" }
    return "${tmp}/vcr_record_chunked.tape"
}

get_body(url: string) -> string {
    req = client.request("GET", url)
    client.set_timeout(req, 5)
    resp, err = client.send_request(req)
    client.request_free(req)
    if err != "" {
        println("FAIL: transport ${err} for ${url}")
        exit(1)
    }
    out = string.concat(client.response_body(resp), "")
    client.response_free(resp)
    return out
}

main() {
    println("=== VCR record chunked dechunk ===")

    up_port = io.getenv("UPSTREAM_PORT")
    if up_port == 0 {
        println("FAIL: UPSTREAM_PORT not set")
        exit(1)
    }
    upstream = "http://127.0.0.1:${up_port}"

    // 1. Client tier: a chunked upstream response decodes to the payload.
    direct = get_body(upstream)
    if direct != BODY {
        println("FAIL: client did not de-chunk; got '${direct}'")
        exit(1)
    }
    println("  PASS: client de-chunks Transfer-Encoding: chunked")

    // 2. Record: the tape stores the decoded payload, not chunk framing.
    TAPE = tape_path()
    fs.delete(TAPE)
    recorder = vcr.load_record(TAPE, upstream, RECORD_PORT)
    if recorder == null { println("FAIL: load_record"); exit(1) }
    serr = http.server_start_background(recorder)
    if serr != "" { println("FAIL: recorder start ${serr}"); exit(1) }
    sleep(250)

    rec_body = get_body("http://127.0.0.1:${RECORD_PORT}/chunked")
    if rec_body != BODY {
        println("FAIL: recorder returned '${rec_body}' to the SUT")
        exit(1)
    }
    ferr = vcr.eject_record(recorder, TAPE)
    if ferr != "" { println("FAIL: eject_record ${ferr}"); exit(1) }

    tape, terr = fs.read(TAPE)
    if terr != "" { println("FAIL: read tape ${terr}"); exit(1) }
    if string.contains(tape, BODY) != 1 {
        println("FAIL: tape missing decoded body")
        exit(1)
    }
    println("  PASS: record tape stores decoded payload")

    // 3. Replay serves the decoded body (framed bytes would fail this).
    playback = vcr.load(TAPE, PLAYBACK_PORT)
    if playback == null { println("FAIL: load playback"); exit(1) }
    serr2 = http.server_start_background(playback)
    if serr2 != "" { println("FAIL: playback start ${serr2}"); exit(1) }
    sleep(250)

    play_body = get_body("http://127.0.0.1:${PLAYBACK_PORT}/chunked")
    if play_body != BODY {
        println("FAIL: playback body '${play_body}' (framing leaked into tape?)")
        exit(1)
    }
    println("  PASS: replay serves decoded body")

    vcr.eject(playback)
    fs.delete(TAPE)
    println("PASS")
    exit(0)
}
