// contrib.templating.liquid — `{% increment %}`, `{% decrement %}`,
// and `{% cycle %}` tags.
//
// Shopify semantics:
//   - First `{% increment x %}` emits "0" and binds x = 1
//   - First `{% decrement x %}` emits "-1" and binds x = -1
//   - increment/decrement share a namespace SEPARATE from `assign`:
//     `{% assign x = "hi" %}` does NOT affect the counter for x.
//   - `{% cycle 'a','b','c' %}` round-robins through the args by
//     position. Identical arg-lists in the same source share state
//     (locked-step). `{% cycle 'name': 'a','b' %}` keys by name.
//
// Cases:
//   1.  First increment emits "0"
//   2.  Second increment emits "1"
//   3.  Three-in-a-row increments emit "0", "1", "2"
//   4.  First decrement emits "-1"
//   5.  Two-in-a-row decrements emit "-1", "-2"
//   6.  Increment x then decrement x: 0, 0  (independent operations
//       on the same name — Shopify keeps a single counter, so
//       increment writes the *next* value, decrement-after-increment
//       sees that value-then-decrements)
//   7.  `assign x` and `increment x` are independent (different
//       namespaces)
//   8.  Three `{% increment a %}` interleaved with one `{% increment b %}`:
//       a=0, b=0, a=1, a=2  (separate counters)
//   9.  Simple cycle 'a','b','c' three times: a, b, c
//   10. Cycle that wraps: 'a','b' four times: a, b, a, b
//   11. Two identical cycles SHARE state (Shopify lockstep)
//   12. Two named cycles 'g1': … and 'g2': … advance independently
//   13. Increment with missing name → error
//   14. Decrement with missing name → error
//   15. Cycle with empty arg list → error

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

main() {
    // (1) First increment emits "0".
    expect_eq(render_empty("{% increment x %}"), "0", "1 first increment")

    // (2) Sequence: two increments -> "01".
    expect_eq(render_empty("{% increment x %}{% increment x %}"),
              "01", "2 two increments")

    // (3) Three increments -> "012".
    expect_eq(render_empty("{% increment x %}-{% increment x %}-{% increment x %}"),
              "0-1-2", "3 three increments")

    // (4) First decrement emits "-1".
    expect_eq(render_empty("{% decrement x %}"), "-1", "4 first decrement")

    // (5) Two decrements -> "-1-2".
    expect_eq(render_empty("{% decrement x %}/{% decrement x %}"),
              "-1/-2", "5 two decrements")

    // (6) Increment then decrement on same name.
    //   First increment: emit 0, store 1
    //   Then decrement:  store 0, emit 0
    expect_eq(render_empty("{% increment x %}/{% decrement x %}"),
              "0/0", "6 inc then dec same name")

    // (7) assign and increment are independent.
    //   {% assign x = "hi" %} does NOT seed the counter for x.
    expect_eq(render_empty("{% assign x = \"hi\" %}|{% increment x %}|{{ x }}"),
              "|0|hi", "7 assign x and increment x independent")

    // (8) Two counters advance independently.
    expect_eq(render_empty("{% increment a %}{% increment b %}{% increment a %}{% increment a %}"),
              "0012", "8 two counters")

    // (9) Cycle 3 args, called 3 times.
    expect_eq(render_empty("{% cycle 'a','b','c' %}-{% cycle 'a','b','c' %}-{% cycle 'a','b','c' %}"),
              "a-b-c", "9 cycle abc")

    // (10) Wrap: 2 args, 4 calls.
    expect_eq(render_empty("{% cycle 'a','b' %}{% cycle 'a','b' %}{% cycle 'a','b' %}{% cycle 'a','b' %}"),
              "abab", "10 cycle wrap")

    // (11) Two identical cycles share state (lockstep).
    //   Calling the SAME cycle args twice advances once per call from the
    //   shared position. So the four calls below emit a,b,a,b — even
    //   though they're textually identical tags.
    expect_eq(render_empty("[{% cycle 'a','b' %}][{% cycle 'a','b' %}][{% cycle 'a','b' %}][{% cycle 'a','b' %}]"),
              "[a][b][a][b]", "11 lockstep cycles")

    // (12) Named cycles advance independently.
    expect_eq(render_empty("{% cycle 'g1': 'a','b' %}{% cycle 'g2': 'X','Y' %}{% cycle 'g1': 'a','b' %}{% cycle 'g2': 'X','Y' %}"),
              "aXbY", "12 named cycles independent")

    // (13) Missing name on increment.
    t13, _ = liquid.parse_string("{% increment %}")
    _, e13 = liquid.render(t13, liquid.context_new())
    if string.equals(e13, "") == 1 {
        println("FAIL 13 increment missing name: expected error")
        exit(1)
    }
    println("PASS 13 increment missing name: '${e13}'")

    // (14) Missing name on decrement.
    t14, _ = liquid.parse_string("{% decrement %}")
    _, e14 = liquid.render(t14, liquid.context_new())
    if string.equals(e14, "") == 1 {
        println("FAIL 14 decrement missing name: expected error")
        exit(1)
    }
    println("PASS 14 decrement missing name: '${e14}'")

    // (15) Cycle with empty args.
    t15, _ = liquid.parse_string("{% cycle %}")
    _, e15 = liquid.render(t15, liquid.context_new())
    if string.equals(e15, "") == 1 {
        println("FAIL 15 cycle empty: expected error")
        exit(1)
    }
    println("PASS 15 cycle empty: '${e15}'")

    println("All PASS")
}
