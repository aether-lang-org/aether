// contrib.templating.liquid — `{% include %}` and `{% render %}` tags.
//
// Both forms require `context_set_include_root(ctx, root)` to be set
// before rendering. The shell driver passes the absolute path to
// the `partials/` directory through `LIQUID_PARTIAL_ROOT`.
//
// `include` lets the partial see (and mutate) the outer context.
// `render` gives the partial a fresh context with only the explicitly
// passed args; outer scope is invisible and any assignments inside
// do NOT escape.
//
// Both forms:
//   - resolve `'name'` to `<root>/name.liquid` (or `'name.liquid'` is
//     used verbatim)
//   - reject path traversal via `fs.is_within_base`
//   - cap recursion at depth 100
//
// Cases:
//   1.  Bare include sees outer var (`name`)
//   2.  Include can omit the `.liquid` suffix
//   3.  Include with explicit `.liquid` suffix
//   4.  Include's assignments LEAK to outer ctx
//   5.  Nested include: outer -> inner
//   6.  Include of a missing partial -> error
//   7.  Include with NO root set -> error
//   8.  Path traversal `'../escapes'` -> error
//   9.  Recursion-depth cap -> error
//   10. Render does NOT see outer ctx (key absent)
//   11. Render receives explicit args
//   12. Render's assignments do NOT escape outer ctx
//   13. Render with multiple args
//   14. Render with a quoted-literal arg
//   15. Render of missing partial -> error
//   16. Include inside a {% for %} loop (each iteration sees forloop.*)
//   17. Recursion via render also capped

import contrib.templating.liquid
import std.string
import std.os

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

main() {
    root = os.getenv("LIQUID_PARTIAL_ROOT")
    if string_length(root) == 0 {
        println("FAIL setup: LIQUID_PARTIAL_ROOT not set")
        exit(1)
    }

    // (1) Bare include sees outer var.
    t1, _ = liquid.parse_string("{% include 'greeting' %}")
    ctx1 = liquid.context_new()
    liquid.context_set_include_root(ctx1, root)
    liquid.context_put_string(ctx1, "name", "alice")
    out1, _ = liquid.render(t1, ctx1)
    expect_eq(out1, "Hello alice!", "1 include sees outer var")

    // (2) Without .liquid suffix.
    t2, _ = liquid.parse_string("[{% include 'greeting' %}]")
    ctx2 = liquid.context_new()
    liquid.context_set_include_root(ctx2, root)
    liquid.context_put_string(ctx2, "name", "bob")
    out2, _ = liquid.render(t2, ctx2)
    expect_eq(out2, "[Hello bob!]", "2 no suffix")

    // (3) Explicit .liquid suffix.
    t3, _ = liquid.parse_string("{% include 'greeting.liquid' %}")
    ctx3 = liquid.context_new()
    liquid.context_set_include_root(ctx3, root)
    liquid.context_put_string(ctx3, "name", "carol")
    out3, _ = liquid.render(t3, ctx3)
    expect_eq(out3, "Hello carol!", "3 explicit suffix")

    // (4) Include leaks assigns to outer.
    //   inner.liquid is just "INNER", so we use a separate partial
    //   that does `{% assign x = "LEAKED" %}`. Reuse list_item with
    //   item="LEAKED" via include.
    t4, _ = liquid.parse_string("{% assign x = \"BEFORE\" %}{% include 'leak' %}/{{ x }}")
    ctx4 = liquid.context_new()
    liquid.context_set_include_root(ctx4, root)
    // We need a partial named 'leak' for this case — see fixture.
    out4, _ = liquid.render(t4, ctx4)
    expect_eq(out4, "/AFTER", "4 include assigns leak (and run first emits nothing)")

    // (5) Nested include outer -> inner.
    t5, _ = liquid.parse_string("{% include 'outer' %}")
    ctx5 = liquid.context_new()
    liquid.context_set_include_root(ctx5, root)
    out5, _ = liquid.render(t5, ctx5)
    expect_eq(out5, "outer-start INNER outer-end", "5 nested include")

    // (6) Missing partial.
    t6, _ = liquid.parse_string("{% include 'nope' %}")
    ctx6 = liquid.context_new()
    liquid.context_set_include_root(ctx6, root)
    _, e6 = liquid.render(t6, ctx6)
    if string.equals(e6, "") == 1 {
        println("FAIL 6 missing partial: expected error")
        exit(1)
    }
    println("PASS 6 missing partial: '${e6}'")

    // (7) No root set.
    t7, _ = liquid.parse_string("{% include 'greeting' %}")
    _, e7 = liquid.render(t7, liquid.context_new())
    if string.equals(e7, "") == 1 {
        println("FAIL 7 no root: expected error")
        exit(1)
    }
    println("PASS 7 no root: '${e7}'")

    // (8) Path traversal.
    t8, _ = liquid.parse_string("{% include '../escape' %}")
    ctx8 = liquid.context_new()
    liquid.context_set_include_root(ctx8, root)
    _, e8 = liquid.render(t8, ctx8)
    if string.equals(e8, "") == 1 {
        println("FAIL 8 traversal: expected error")
        exit(1)
    }
    println("PASS 8 traversal: '${e8}'")

    // (9) Recursion depth cap via include.
    t9, _ = liquid.parse_string("{% include 'loop' %}")
    ctx9 = liquid.context_new()
    liquid.context_set_include_root(ctx9, root)
    _, e9 = liquid.render(t9, ctx9)
    if string.equals(e9, "") == 1 {
        println("FAIL 9 recursion cap: expected error")
        exit(1)
    }
    println("PASS 9 recursion cap: '${e9}'")

    // (10) Render hides outer ctx.
    t10, _ = liquid.parse_string("[{% render 'greeting' %}]")
    ctx10 = liquid.context_new()
    liquid.context_set_include_root(ctx10, root)
    liquid.context_put_string(ctx10, "name", "alice")
    out10, _ = liquid.render(t10, ctx10)
    expect_eq(out10, "[Hello !]", "10 render hides outer ctx")

    // (11) Render gets explicit args.
    t11, _ = liquid.parse_string("{% render 'greeting', name: \"explicit\" %}")
    ctx11 = liquid.context_new()
    liquid.context_set_include_root(ctx11, root)
    out11, _ = liquid.render(t11, ctx11)
    expect_eq(out11, "Hello explicit!", "11 render explicit args")

    // (12) Render's assigns don't leak.
    t12, _ = liquid.parse_string("{% assign x = \"OUTER\" %}{% render 'leak' %}/{{ x }}")
    ctx12 = liquid.context_new()
    liquid.context_set_include_root(ctx12, root)
    out12, _ = liquid.render(t12, ctx12)
    expect_eq(out12, "/OUTER", "12 render isolates assigns")

    // (13) Render multi-arg from outer var.
    t13, _ = liquid.parse_string("{% render 'pair', a: x, b: y %}")
    ctx13 = liquid.context_new()
    liquid.context_set_include_root(ctx13, root)
    liquid.context_put_string(ctx13, "x", "X-val")
    liquid.context_put_string(ctx13, "y", "Y-val")
    out13, _ = liquid.render(t13, ctx13)
    expect_eq(out13, "a=X-val|b=Y-val", "13 render multi-arg")

    // (14) Render with quoted literal arg.
    t14, _ = liquid.parse_string("{% render 'greeting', name: 'lit' %}")
    ctx14 = liquid.context_new()
    liquid.context_set_include_root(ctx14, root)
    out14, _ = liquid.render(t14, ctx14)
    expect_eq(out14, "Hello lit!", "14 render quoted literal")

    // (15) Missing render partial.
    t15, _ = liquid.parse_string("{% render 'nope' %}")
    ctx15 = liquid.context_new()
    liquid.context_set_include_root(ctx15, root)
    _, e15 = liquid.render(t15, ctx15)
    if string.equals(e15, "") == 1 {
        println("FAIL 15 missing render partial: expected error")
        exit(1)
    }
    println("PASS 15 missing render partial: '${e15}'")

    // (16) Include inside a for-loop.
    t16, _ = liquid.parse_string("{% for i in (1..3) %}{% assign item = i %}{% include 'list_item' %}{% endfor %}")
    ctx16 = liquid.context_new()
    liquid.context_set_include_root(ctx16, root)
    out16, _ = liquid.render(t16, ctx16)
    expect_eq(out16, "[1][2][3]", "16 include in for-loop")

    // (17) Render recursion also capped — using `loop` but render-style
    //   would also infinite-loop. The same depth counter applies.
    t17, _ = liquid.parse_string("{% render 'loop' %}")
    ctx17 = liquid.context_new()
    liquid.context_set_include_root(ctx17, root)
    _, e17 = liquid.render(t17, ctx17)
    if string.equals(e17, "") == 1 {
        println("FAIL 17 render recursion cap: expected error")
        exit(1)
    }
    println("PASS 17 render recursion cap: '${e17}'")

    println("All PASS")
}
