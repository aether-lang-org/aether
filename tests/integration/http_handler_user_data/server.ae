// #633 regression: a non-zero `user_data` ptr passed to
// http_server_get reaches the handler. Pre-fix the C plumbing
// already worked end-to-end, but no example or test exercised it
// from Aether — downstream porters (fbs-core) concluded the slot
// was unusable from Aether and dropped to a C shim of process
// statics. This test pins the working pattern.
//
// The pattern: build a per-server context struct, stash its `ptr`
// in the user_data slot via mem.ptr_to_long → mem.long_to_ptr
// inside the handler. Each route can carry its own context
// pointer — perfect fit for "this route owns this DB handle" or
// "this route's auth scheme is X".

import std.http
import std.mem
import std.os
import std.string

extern exit(code: int)
extern malloc(n: int) -> ptr
extern http_server_start_raw(server: ptr) -> int

const PORT = 18299

// Per-route context the handler reads back from the user_data slot.
// Fields stand in for "DB handle + data-dir" — same shape as the
// fbs-core appstate.c shim that motivated #633.
struct AppCtx {
    label: string
    db_id: int
}

// Two handlers showing per-route ud reaches each handler intact, so
// a single server can host routes with distinct contexts (the
// pattern the docs need to bless explicitly).
handle_a(req: ptr, res: ptr, ud: ptr) {
    ctx = ud as *AppCtx
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    label = ctx.label
    db_id = ctx.db_id
    http.response_set_body(res, "a: label=${label} db_id=${db_id}")
}

handle_b(req: ptr, res: ptr, ud: ptr) {
    ctx = ud as *AppCtx
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    label = ctx.label
    db_id = ctx.db_id
    http.response_set_body(res, "b: label=${label} db_id=${db_id}")
}

// Demonstrates that ud == 0 still works (the existing pattern stays
// valid — opting in to user_data is purely additive).
handle_no_ctx(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_header(res, "Content-Type", "text/plain")
    if mem.ptr_to_long(ud) == 0 {
        http.response_set_body(res, "ud=null")
    } else {
        http.response_set_body(res, "ud=present")
    }
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 {
        println("FAIL: server_create returned null")
        exit(1)
    }

    // Two heap-allocated contexts, one per route. malloc-then-init
    // gives the handler a stable `ptr` to read back via
    // `ud as *AppCtx`. The struct lives for the lifetime of the
    // server (the process); a real port that wanted to re-register
    // routes would also free the previous context.
    ctx_a = malloc(64) as *AppCtx
    ctx_a.label = "alpha"
    ctx_a.db_id = 11

    ctx_b = malloc(64) as *AppCtx
    ctx_b.label = "beta"
    ctx_b.db_id = 22

    http.server_get(raw, "/a", handle_a, ctx_a)
    http.server_get(raw, "/b", handle_b, ctx_b)
    http.server_get(raw, "/n", handle_no_ctx, 0)

    println("READY")

    spawn(SchedHelper())
    srv_actor = spawn(SrvActor())
    srv_actor ! StartSrv { raw: raw }

    sleep(60000)
    exit(0)
}
