// Integration probe for the heap-ownership-return-propagation fix.
//
// A function whose return expression is `bytes.finish(...)` is now
// classified heap-returning, and the value it yields is freed at
// every call site through an AetherString-aware free (string_release,
// reclaiming both the struct and its data buffer). Pre-fix, such a
// value leaked at every call site — avn's commit server ramped
// ~430 KB/commit, ending a 5000-commit bench at 2.57 GB RSS where
// classic svnserve plateaus at 31 MB (heap-ownership-return-
// propagation.md).
//
// This probe runs 5000 iterations of a heap-returning concat chain —
// `rep_encode_blob` builds an inner blob, wraps it in an envelope,
// returns it; both intermediates and the result are bytes.finish
// values — and bounds RSS growth. A leak of the per-iteration blob,
// its envelope, and the wrapper temporaries would be tens of MB; the
// fixed build stays flat.

import std.bytes
import std.string

extern getrusage_max_rss_kb() -> int
extern exit(code: int)

// Heap-returning leaf: builds a binary-safe blob and hands it off.
blob(prefix: string, body: string) -> string {
    plen = string.length(prefix)
    blen = string.length(body)
    total = plen + blen
    buf = bytes.new(total + 1)
    bytes.copy_from_string(buf, 0, prefix, plen)
    bytes.copy_from_string(buf, plen, body, blen)
    return bytes.finish(buf, total)
}

// Wrapper chain: payload + envelope, every step a heap-returning call.
rep_encode_blob(body: string) -> string {
    payload = blob("tag:", body)
    return blob("<", payload)
}

// One encode cycle; the returned heap string is dropped at scope exit
// and must be reclaimed by the function-exit defer-free.
encode_once() -> int {
    out = rep_encode_blob("the-quick-brown-fox-jumps")
    return string.length(out)
}

main() {
    println("=== bytes_finish_return_no_leak ===")

    // Portability gate: Windows MinGW has no getrusage — smoke only.
    rss_probe = getrusage_max_rss_kb()
    if rss_probe < 0 {
        n = encode_once()
        if n <= 0 {
            println("  FAIL: smoke encode produced empty result")
            exit(1)
        }
        println("  PASS: smoke (getrusage unavailable)")
        println("=== all cases passed ===")
        return
    }

    // Warm to steady state.
    w = 0
    while w < 200 {
        encode_once()
        w = w + 1
    }
    rss_before = getrusage_max_rss_kb()
    i = 0
    while i < 5000 {
        len = encode_once()
        if len <= 0 {
            println("  FAIL: iteration ${i} produced empty result")
            exit(1)
        }
        i = i + 1
    }
    rss_after = getrusage_max_rss_kb()
    growth = rss_after - rss_before
    // Pre-fix: each iteration leaks the blob, its envelope, and the
    // wrapper temporaries — a multi-MB monotonic ramp over 5000 iters.
    // Post-fix the loop is flat; 1 MB is generous allocator slack.
    if growth > 1024 {
        println("  FAIL: RSS grew ${growth} KB over 5000 encode cycles")
        exit(1)
    }
    println("  PASS: 5000 heap-returning encode cycles, RSS bounded (+${growth} KB)")
    println("=== all cases passed ===")
}
