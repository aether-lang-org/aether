// #1004: streaming HTTP response bodies. Self-contained differential test —
// spins up an in-process Aether HTTP server that serves a large (128 KiB) body,
// then fetches the SAME URL two ways:
//   (a) buffered  — client.send_request + client.response_body
//   (b) streamed  — client.send_stream + a client.response_read loop
// and asserts the streamed reassembly is byte-identical to the buffered body.
// This exercises the header-only read, the transport-stays-open handoff, the
// incremental Content-Length decoder across many 64 KiB windows (including the
// over-read past the header terminator), and teardown on response_free.
//
// The body is NUL-free so string.equals (strcmp-based) is a valid byte compare;
// lengths are checked independently to catch any truncation.

import std.http.client
import std.http
import std.string

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18097

// 64-byte NUL-free seed, doubled 11 times -> 64 * 2048 = 131072 bytes (128 KiB).
build_big() -> string {
    s = "ABCDEFGHIJKLMNOPQRSTUVWXYZ0123456789abcdefghijklmnopqrstuvwxyz+/="
    i = 0
    while i < 11 {
        s = string.concat(s, s)
        i = i + 1
    }
    return s
}

handle_big(req: ptr, res: ptr, ud: ptr) {
    http.response_set_status(res, 200)
    http.response_set_body(res, build_big())
}

message StartSrv { raw: ptr }
message Noop {}

actor SrvActor {
    state s = 0
    receive {
        StartSrv(raw) -> {
            s = raw
            http_server_start_raw(raw)
        }
    }
}

actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

base_url() -> string { return "http://127.0.0.1:${PORT}" }

main() {
    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 {
        println("FAIL: server_create returned 0")
        exit(1)
    }
    http.server_get(raw, "/big", handle_big, 0)

    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }

    // Poll until the listener is answering.
    ready = 0
    i = 0
    while i < 200 {
        sleep(25)
        pr = client.request("GET", "${base_url()}/big")
        if pr != null {
            client.set_timeout(pr, 2s)
            presp, perr = client.send_request(pr)
            client.request_free(pr)
            if perr == "" {
                client.response_free(presp)
                ready = 1
                i = 200
            }
        }
        i = i + 1
    }
    if ready == 0 {
        println("FAIL: server never reached ready state")
        exit(1)
    }

    expected = build_big()
    want_len = string.length(expected)

    // (a) buffered fetch
    rb = client.request("GET", "${base_url()}/big")
    client.set_timeout(rb, 10s)
    bresp, berr = client.send_request(rb)
    client.request_free(rb)
    if berr != "" { println("FAIL buffered transport: ${berr}"); exit(1) }
    if client.response_is_stream(bresp) != 0 {
        println("FAIL: buffered response reported as stream"); exit(1)
    }
    buffered = client.response_body(bresp)
    blen = client.response_body_length(bresp)
    client.response_free(bresp)
    if blen != want_len {
        println("FAIL buffered length: got ${blen}, want ${want_len}"); exit(1)
    }

    // (b) streamed fetch
    rs = client.request("GET", "${base_url()}/big")
    client.set_timeout(rs, 10s)
    sresp, serr = client.send_stream(rs)
    client.request_free(rs)
    if serr != "" { println("FAIL stream transport: ${serr}"); exit(1) }
    if client.response_is_stream(sresp) != 1 {
        println("FAIL: streamed response not reported as stream"); exit(1)
    }
    if client.response_status(sresp) != 200 {
        println("FAIL: streamed status ${client.response_status(sresp)}"); exit(1)
    }

    streamed = ""
    total = 0
    reads = 0
    done = 0
    while done == 0 {
        chunk = client.response_read(sresp, 65536)
        n = string.length(chunk)
        if n == 0 {
            done = 1
        } else {
            streamed = string.concat(streamed, chunk)
            total = total + n
            reads = reads + 1
        }
    }
    read_err = client.response_error(sresp)
    client.response_free(sresp)

    if read_err != "" { println("FAIL stream read error: ${read_err}"); exit(1) }
    if total != want_len {
        println("FAIL stream length: got ${total}, want ${want_len}"); exit(1)
    }
    if reads < 2 {
        println("FAIL: expected multiple read windows for 128 KiB, got ${reads}"); exit(1)
    }
    if !string.equals(streamed, expected) {
        println("FAIL: streamed bytes differ from expected"); exit(1)
    }
    if !string.equals(streamed, buffered) {
        println("FAIL: streamed bytes differ from buffered"); exit(1)
    }

    println("PASS: streamed ${total} bytes over ${reads} windows, byte-identical to buffered")
    exit(0)
}
