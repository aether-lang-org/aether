// contrib.templating.liquid — additional string-only filters.
//
// Cases:
//   1.  replace_first only rewrites the first hit
//   2.  remove drops every occurrence
//   3.  remove_first drops only the first
//   4.  escape escapes &, <, >, ", '
//   5.  escape on text without special chars is identity
//   6.  escape_once skips already-encoded `&amp;` but still escapes `<`
//   7.  escape_once on doubly-applicable text: `&` becomes `&amp;`,
//       `&amp;` stays `&amp;`
//   8.  url_encode keeps unreserved, turns space into `+`, percent-encodes the rest
//   9.  url_decode inverts `+` and `%HH`
//   10. url_decode is forgiving on malformed `%`
//   11. truncatewords cuts at the word boundary and adds "..."
//   12. truncatewords on a string with fewer words is identity
//   13. truncatewords collapses runs of whitespace between kept words
//   14. newline_to_br inserts <br /> before each \n (keeping the \n)
//   15. newline_to_br treats \r\n the same as \n (single <br />)
//   16. Chained: x | escape | upcase
//   17. Chained: x | url_encode | append:"&z=1"
//   18. Unknown filter still errors

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_with_name(src: string, key: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, key, val)
    out, _ = liquid.render(t, ctx)
    return out
}

main() {
    // (1) replace_first only rewrites the first.
    expect_eq(render_with_name("{{ s | replace_first:\"foo\",\"bar\" }}", "s", "foo foo foo"),
              "bar foo foo", "1 replace_first")

    // (2) remove drops every occurrence.
    expect_eq(render_with_name("{{ s | remove:\"x\" }}", "s", "xaxbxcx"), "abc", "2 remove all")

    // (3) remove_first drops only the first.
    expect_eq(render_with_name("{{ s | remove_first:\"x\" }}", "s", "xaxbxcx"),
              "axbxcx", "3 remove_first")

    // (4) escape: full set.
    expect_eq(render_with_name("{{ s | escape }}", "s", "<a href=\"x\">'a'&b</a>"),
              "&lt;a href=&quot;x&quot;&gt;&#39;a&#39;&amp;b&lt;/a&gt;",
              "4 escape full set")

    // (5) escape is identity on plain text.
    expect_eq(render_with_name("{{ s | escape }}", "s", "hello world"),
              "hello world", "5 escape identity")

    // (6) escape_once: `<` still escapes; existing `&amp;` survives.
    expect_eq(render_with_name("{{ s | escape_once }}", "s", "a &amp; b < c"),
              "a &amp; b &lt; c", "6 escape_once preserves entity")

    // (7) escape_once: bare `&` gets encoded; pre-encoded one does not.
    expect_eq(render_with_name("{{ s | escape_once }}", "s", "& and &amp;"),
              "&amp; and &amp;", "7 escape_once idempotent")

    // (8) url_encode: unreserved + space + percent-encoded.
    expect_eq(render_with_name("{{ s | url_encode }}", "s", "a b/c=1"),
              "a+b%2Fc%3D1", "8 url_encode")

    // (9) url_decode inverse.
    expect_eq(render_with_name("{{ s | url_decode }}", "s", "a+b%2Fc%3D1"),
              "a b/c=1", "9 url_decode inverse")

    // (10) Malformed `%` is forgiving.
    expect_eq(render_with_name("{{ s | url_decode }}", "s", "a%ZZb"), "a%ZZb",
              "10 url_decode malformed")

    // (11) truncatewords keeps N words + adds "...".
    expect_eq(render_with_name("{{ s | truncatewords:\"3\" }}", "s", "one two three four five"),
              "one two three...", "11 truncatewords cuts")

    // (12) truncatewords on a short string is identity.
    expect_eq(render_with_name("{{ s | truncatewords:\"10\" }}", "s", "a b c"),
              "a b c", "12 truncatewords identity")

    // (13) truncatewords collapses inter-word whitespace runs.
    expect_eq(render_with_name("{{ s | truncatewords:\"3\" }}",
                               "s", "one   two\t\tthree four"),
              "one two three...", "13 truncatewords collapses whitespace")

    // (14) newline_to_br inserts <br /> before each \n.
    expect_eq(render_with_name("{{ s | newline_to_br }}", "s", "a\nb\nc"),
              "a<br />\nb<br />\nc", "14 newline_to_br lf")

    // (15) newline_to_br treats CRLF as a single line break.
    expect_eq(render_with_name("{{ s | newline_to_br }}", "s", "a\r\nb"),
              "a<br />\nb", "15 newline_to_br crlf")

    // (16) Chain: escape then upcase.
    expect_eq(render_with_name("{{ s | escape | upcase }}", "s", "a<b"),
              "A&LT;B", "16 escape | upcase")

    // (17) Chain: url_encode then append literal `&z=1`.
    expect_eq(render_with_name("{{ s | url_encode | append:\"&z=1\" }}", "s", "key=val"),
              "key%3Dval&z=1", "17 url_encode | append")

    // (18) Unknown filter passes through unchanged (Shopify behaviour).
    t18, _ = liquid.parse_string("{{ s | bogosity }}")
    ctx18 = liquid.context_new()
    liquid.context_put_string(ctx18, "s", "x")
    out18, e18 = liquid.render(t18, ctx18)
    if string.equals(e18, "") == 0 {
        println("FAIL 18 unknown filter: unexpected error '${e18}'")
        exit(1)
    }
    expect_eq(out18, "x", "18 unknown filter passes through")

    println("All PASS")
}
