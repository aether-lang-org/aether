// contrib.templating.liquid — `{{- -}}` and `{%- -%}` whitespace control.
//
// Cases:
//   1.  `{{- x }}` strips trailing whitespace of preceding TEXT
//   2.  `{{ x -}}` strips leading whitespace of next TEXT
//   3.  Both sides: `{{- x -}}`
//   4.  No whitespace at all is fine (no-op)
//   5.  Tag form: `{%- assign ... -%}` works on the tag opener
//   6.  `{%- comment %}body{% endcomment -%}` strips around the block
//   7.  `{%- raw -%}body{%- endraw -%}` opener-right + closer-left
//       trim INSIDE the raw text, closer-right strips next TEXT
//   8.  `raw` without dashes preserves leading/trailing whitespace
//       of the body (verifies our refactor didn't regress v0)
//   9.  Multi-line newline run is fully consumed by a single `-`
//   10. Two consecutive `{%- ... -%}` tags collapse the whitespace
//       between them and adjacent text
//   11. `{{- x }}` at the start of source (no preceding TEXT) is a no-op
//       on the left side
//   12. `{{ x -}}` at the end of source (no following TEXT) is a no-op
//       on the right side

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_x(src: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, "x", val)
    out, _ = liquid.render(t, ctx)
    return out
}

main() {
    // (1) Left-strip eats trailing whitespace of preceding TEXT.
    expect_eq(render_x("hi   {{- x }}", "X"), "hiX", "1 left-strip preceding text")

    // (2) Right-strip eats leading whitespace of next TEXT.
    expect_eq(render_x("{{ x -}}   END", "X"), "XEND", "2 right-strip next text")

    // (3) Both sides.
    expect_eq(render_x("hi   {{- x -}}   END", "X"),
              "hiXEND", "3 both sides")

    // (4) No whitespace at all is a no-op.
    expect_eq(render_x("hi{{- x -}}END", "X"), "hiXEND", "4 no-op when no ws")

    // (5) Tag form on `{% assign %}`.
    t5, _ = liquid.parse_string("a   {%- assign x = \"X\" -%}   {{ x }}")
    out5, _ = liquid.render(t5, liquid.context_new())
    expect_eq(out5, "aX", "5 tag form on assign")

    // (6) `comment` block: both sides strip outer whitespace.
    expect_eq(render_x("a   {%- comment %}hidden{% endcomment -%}   b",
                       "ignored"),
              "ab", "6 comment outer trim")

    // (7) `raw` block: opener-right trims raw body LEADING ws;
    //     closer-left trims raw body TRAILING ws; closer-right trims
    //     the next TEXT.
    expect_eq(render_x("a {%- raw -%}   inside   {%- endraw -%}   b",
                       "ignored"),
              "ainsideb", "7 raw inner + outer trim")

    // (8) Dash-less raw preserves whitespace inside its body.
    expect_eq(render_x("{% raw %}   keep   {% endraw %}",
                       "ignored"),
              "   keep   ", "8 raw without dashes preserves")

    // (9) Multi-line whitespace consumed by a single `-`.
    expect_eq(render_x("hi\n\n   {{- x }}", "X"),
              "hiX", "9 multi-line ws strip")

    // (10) Two `{%- ... -%}` in a row collapse intervening ws.
    t10, _ = liquid.parse_string("a   {%- assign x = \"X\" -%}   {%- assign y = \"Y\" -%}   {{ x }}{{ y }}")
    out10, _ = liquid.render(t10, liquid.context_new())
    expect_eq(out10, "aXY", "10 two stripping tags in a row")

    // (11) Left-strip with no preceding TEXT is a no-op on the left.
    expect_eq(render_x("{{- x }}", "X"), "X", "11 leading left-strip no-op")

    // (12) Right-strip with no following TEXT is a no-op on the right.
    expect_eq(render_x("{{ x -}}", "X"), "X", "12 trailing right-strip no-op")

    println("All PASS")
}
