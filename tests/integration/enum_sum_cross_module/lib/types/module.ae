// A library module owning an `enum` and a `sum type`, with accessors that use
// them by name — the same imported-type-emission shape as bitstructs.
//
// Before the fix, module_merge_into_program cloned imported struct/bitstruct
// definitions into the consumer's program AST but NOT enum or sum-type ones,
// so an imported enum/sum used by name failed: `Undefined variable 'Color'`
// at type-check, or `unknown type name 'Shape'` in the generated C.

enum Color { Red, Green, Blue }

// Sum-type variants are struct types; they are merged as ordinary structs.
struct Circle { r: int }
struct Rect { w: int, h: int }
type Shape = Circle | Rect

default_color() -> Color { return Color.Green }

color_code(c: Color) -> int {
    match c {
        Color.Red   -> { return 0 }
        Color.Green -> { return 1 }
        Color.Blue  -> { return 2 }
    }
}

a_rect() -> Shape { return Rect { w: 3, h: 4 } }

shape_kind(s: Shape) -> int {
    match s {
        Circle -> { return 1 }
        Rect   -> { return 2 }
    }
    return 0
}
