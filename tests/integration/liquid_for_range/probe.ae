// contrib.templating.liquid — `{% for VAR in (LO..HI) %}` range
// iteration with `forloop.*` variables, `limit:N`, `offset:N`,
// `reversed`, plus `{% break %}` and `{% continue %}`.
//
// Array iteration (`{% for x in collection %}`) waits for the value
// model — this slice supports ONLY the range form. We assert that
// the non-range form gives a clear error.
//
// Cases:
//   1.  Bare range: `{% for i in (1..3) %}{{ i }}{% endfor %}` → "123"
//   2.  Range with text: separator between iterations
//   3.  Empty range when HI < LO yields nothing
//   4.  Single-element range (LO == HI) yields one element
//   5.  forloop.index counts from 1
//   6.  forloop.index0 counts from 0
//   7.  forloop.first is "true" only on first
//   8.  forloop.last is "true" only on last
//   9.  forloop.length is the iteration count
//   10. forloop.rindex / rindex0
//   11. Nested for loops: outer i, inner j
//   12. Inner forloop.first/last are scoped to the INNER loop
//   13. Loop variable is restored to its prior value after the loop
//   14. limit:N caps the count
//   15. offset:N drops from the front
//   16. limit + offset together
//   17. reversed flips direction
//   18. reversed + limit takes the LAST N (i.e. limit applies AFTER reverse? no — limit is applied first then reversed reverses the WINDOW)
//   19. break inside the body exits the loop
//   20. continue inside the body skips remainder of that iteration
//   21. break / continue outside a for is a render error
//   22. if + for: conditional loop body
//   23. for + if-with-forloop.first: emit comma between items
//   24. for with capture inside binds the captured string (last wins)
//   25. Bounds via variables: assign LO and HI then range over them
//   26. Whitespace control with for ({%- for / endfor -%})
//   27. Unmatched for → render error
//   28. Stray endfor → render error
//   29. Non-range iterable → clear error
//   30. break in nested for exits only the INNER loop

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

render_with(src: string, key: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, key, val)
    out, _ = liquid.render(t, ctx)
    return out
}

main() {
    // (1) Bare range 1..3
    expect_eq(render_empty("{% for i in (1..3) %}{{ i }}{% endfor %}"),
              "123", "1 bare range 1..3")

    // (2) Text between iterations.
    expect_eq(render_empty("[{% for i in (1..3) %}{{ i }};{% endfor %}]"),
              "[1;2;3;]", "2 range with separator")

    // (3) HI < LO is empty.
    expect_eq(render_empty("[{% for i in (5..1) %}{{ i }}{% endfor %}]"),
              "[]", "3 empty range")

    // (4) LO == HI is single element.
    expect_eq(render_empty("{% for i in (4..4) %}{{ i }}{% endfor %}"),
              "4", "4 single-element range")

    // (5) forloop.index (1-based).
    expect_eq(render_empty("{% for i in (10..12) %}{{ forloop.index }};{% endfor %}"),
              "1;2;3;", "5 forloop.index")

    // (6) forloop.index0 (0-based).
    expect_eq(render_empty("{% for i in (10..12) %}{{ forloop.index0 }};{% endfor %}"),
              "0;1;2;", "6 forloop.index0")

    // (7) forloop.first.
    expect_eq(render_empty("{% for i in (1..3) %}{{ forloop.first }};{% endfor %}"),
              "true;false;false;", "7 forloop.first")

    // (8) forloop.last.
    expect_eq(render_empty("{% for i in (1..3) %}{{ forloop.last }};{% endfor %}"),
              "false;false;true;", "8 forloop.last")

    // (9) forloop.length.
    expect_eq(render_empty("{% for i in (1..3) %}{{ forloop.length }};{% endfor %}"),
              "3;3;3;", "9 forloop.length")

    // (10) forloop.rindex / rindex0.
    expect_eq(render_empty("{% for i in (1..3) %}{{ forloop.rindex }}/{{ forloop.rindex0 }};{% endfor %}"),
              "3/2;2/1;1/0;", "10 forloop.rindex/rindex0")

    // (11) Nested loops.
    expect_eq(render_empty("{% for i in (1..2) %}{% for j in (1..2) %}({{ i }},{{ j }}){% endfor %}{% endfor %}"),
              "(1,1)(1,2)(2,1)(2,2)", "11 nested for")

    // (12) Inner forloop.first scoped to inner only.
    expect_eq(render_empty("{% for i in (1..2) %}{% for j in (1..2) %}{{ forloop.first }};{% endfor %}|{% endfor %}"),
              "true;false;|true;false;|", "12 inner forloop.first")

    // (13) Loop var restored after loop.
    expect_eq(render_with("[{{ i }}]{% for i in (1..2) %}{% endfor %}[{{ i }}]",
                          "i", "PRE"),
              "[PRE][PRE]", "13 loop var restored")

    // (14) limit:N.
    expect_eq(render_empty("{% for i in (1..10) limit:3 %}{{ i }};{% endfor %}"),
              "1;2;3;", "14 limit caps")

    // (15) offset:N.
    expect_eq(render_empty("{% for i in (1..5) offset:2 %}{{ i }};{% endfor %}"),
              "3;4;5;", "15 offset skips front")

    // (16) limit + offset.
    expect_eq(render_empty("{% for i in (1..10) offset:2 limit:3 %}{{ i }};{% endfor %}"),
              "3;4;5;", "16 limit+offset")

    // (17) reversed flips.
    expect_eq(render_empty("{% for i in (1..3) reversed %}{{ i }};{% endfor %}"),
              "3;2;1;", "17 reversed")

    // (18) reversed + limit: limit applied first, then reverse the window.
    //   (1..10) limit:3 -> [1,2,3]; reversed -> [3,2,1]
    expect_eq(render_empty("{% for i in (1..10) limit:3 reversed %}{{ i }};{% endfor %}"),
              "3;2;1;", "18 reversed + limit")

    // (19) break exits loop.
    expect_eq(render_empty("{% for i in (1..5) %}{% if i == \"3\" %}{% break %}{% endif %}{{ i }};{% endfor %}"),
              "1;2;", "19 break")

    // (20) continue skips rest of iteration.
    expect_eq(render_empty("{% for i in (1..5) %}{% if i == \"3\" %}{% continue %}{% endif %}{{ i }};{% endfor %}"),
              "1;2;4;5;", "20 continue")

    // (21) break outside a for is an error.
    t21, _ = liquid.parse_string("plain {% break %} text")
    _, e21 = liquid.render(t21, liquid.context_new())
    if string.equals(e21, "") == 1 {
        println("FAIL 21 stray break: expected error")
        exit(1)
    }
    println("PASS 21 stray break: '${e21}'")

    // (22) Conditional in body.
    expect_eq(render_empty("{% for i in (1..4) %}{% if i == \"2\" or i == \"4\" %}{{ i }};{% endif %}{% endfor %}"),
              "2;4;", "22 if inside for")

    // (23) Comma between items via forloop.first.
    expect_eq(render_empty("{% for i in (1..3) %}{% unless forloop.first %},{% endunless %}{{ i }}{% endfor %}"),
              "1,2,3", "23 comma via forloop.first")

    // (24) Capture inside the body — last iteration's value wins.
    expect_eq(render_empty("{% for i in (1..3) %}{% capture last %}I{{ i }}{% endcapture %}{% endfor %}[{{ last }}]"),
              "[I3]", "24 capture inside body, last wins")

    // (25) LO and HI from variables.
    t25, _ = liquid.parse_string("{% for i in (lo..hi) %}{{ i }};{% endfor %}")
    ctx25 = liquid.context_new()
    liquid.context_put_string(ctx25, "lo", "5")
    liquid.context_put_string(ctx25, "hi", "7")
    out25, _ = liquid.render(t25, ctx25)
    expect_eq(out25, "5;6;7;", "25 LO/HI from variables")

    // (26) Whitespace control.
    expect_eq(render_empty("a   {%- for i in (1..2) -%}   {{ i }}   {%- endfor -%}   b"),
              "a12b", "26 whitespace control around for")

    // (27) Unmatched for.
    t27, _ = liquid.parse_string("{% for i in (1..3) %}body never closed")
    _, e27 = liquid.render(t27, liquid.context_new())
    if string.equals(e27, "") == 1 {
        println("FAIL 27 unmatched for: expected error")
        exit(1)
    }
    println("PASS 27 unmatched for: '${e27}'")

    // (28) Stray endfor.
    t28, _ = liquid.parse_string("hi {% endfor %} bye")
    _, e28 = liquid.render(t28, liquid.context_new())
    if string.equals(e28, "") == 1 {
        println("FAIL 28 stray endfor: expected error")
        exit(1)
    }
    println("PASS 28 stray endfor: '${e28}'")

    // (29) Non-range iterable -> clear error.
    t29, _ = liquid.parse_string("{% for x in mylist %}{{ x }}{% endfor %}")
    _, e29 = liquid.render(t29, liquid.context_new())
    if string.equals(e29, "") == 1 {
        println("FAIL 29 non-range iterable: expected error")
        exit(1)
    }
    println("PASS 29 non-range iterable: '${e29}'")

    // (30) break in nested only exits inner.
    expect_eq(render_empty("{% for i in (1..3) %}[{% for j in (1..5) %}{% if j == \"3\" %}{% break %}{% endif %}{{ j }}{% endfor %}]{% endfor %}"),
              "[12][12][12]", "30 break in inner only")

    println("All PASS")
}
