// contrib.host.aether end-to-end driver.
//
// Exercises the simplest rung of the Aether-hosts-Aether bridge:
// compile a child .ae to a native binary, then run it as a subprocess
// (no sandbox) and confirm it executed (exit code 0). The child writes
// a sentinel line to its own stdout.
//
// The sandbox rungs (run_sandboxed / *_with_map) need libaether_sandbox.so
// + the LD_PRELOAD path; this driver stays on the unsandboxed path so it
// is portable across the CI matrix. test_host_aether.sh sets
// AETHER_HOST_CHILD to the absolute path of the child script and skips
// the whole test unless the toolchain (AETHER_AE_PATH) is available.
import contrib.host.aether
import std.os
import std.string

main() {
    child = os_getenv("AETHER_HOST_CHILD")
    if string.length(child) == 0 {
        println("FAIL: AETHER_HOST_CHILD unset")
        exit(1)
    }

    // Compile + run (no sandbox). Returns the child's exit code.
    rc = aether_host_run_script(child)
    if rc != 0 {
        println("FAIL run_script rc=${rc}")
        exit(1)
    }

    println("PASS: aether host compile + run round-trip")
}
