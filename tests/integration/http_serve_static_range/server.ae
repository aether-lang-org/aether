// #641 regression: http.serve_static honours the Range header,
// emitting 206 + Content-Range for byte slices, 416 for
// unsatisfiable ranges, 200 with Accept-Ranges for whole-file
// requests.

import std.http
import std.os
import std.fs

extern exit(code: int)
extern http_server_start_raw(server: ptr) -> int

const PORT = 18301

handler(req: ptr, res: ptr, ud: ptr) {
    http.serve_static(req, res, ud)
}

message StartSrv { raw: ptr }
message Noop {}
actor SrvActor {
    state s = 0
    receive { StartSrv(raw) -> { s = raw; http_server_start_raw(raw) } }
}
actor SchedHelper {
    state x = 0
    receive { Noop() -> { x = 1 } }
}

main() {
    base = os_getenv("TEST_BASE")
    if base == 0 {
        // When invoked standalone (no env var), skip — the real
        // test driver in test_http_serve_static_range.sh sets
        // TEST_BASE before launching us.
        println("SKIP: TEST_BASE unset (run via test_http_serve_static_range.sh)")
        exit(0)
    }

    raw = http.server_create(PORT)
    http.server_set_host(raw, "127.0.0.1")
    if raw == 0 {
        println("FAIL: server_create")
        exit(1)
    }
    http.server_get(raw, "/*", handler, base)

    println("READY")
    spawn(SchedHelper())
    a = spawn(SrvActor())
    a ! StartSrv { raw: raw }
    sleep(60000)
    exit(0)
}
