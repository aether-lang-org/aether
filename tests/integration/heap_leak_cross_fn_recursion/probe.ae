// Regression: cross-function + recursion + bare-identifier-return
// of a heap-tracked-local. avn's commit handler hot path.
// See lib/dirwalk/module.ae for the trigger-shape rationale.

import std.string
import dirwalk

extern getrusage_max_rss_kb() -> int
extern exit(code: int)

main() {
    println("=== heap_leak_cross_fn_recursion ===")

    // Portability gate (Windows MinGW has no getrusage).
    rss_probe = getrusage_max_rss_kb()
    if rss_probe < 0 {
        // Smoke-test: cross-fn recursion returns correct content.
        s_smoke = dirwalk.rebuild_dir(3, 5)
        if string.length(s_smoke) < 100 {
            println("FAIL smoke: length=${string.length(s_smoke)}, expected > 100")
            exit(1)
        }
        println("  PASS: getrusage unavailable, smoke-only — codegen path runs correctly")
        println("=== all cases passed ===")
        return
    }

    // Warm-up LOOP. A single call leaves the allocator's arenas to grow
    // *inside* the measured loop, and max_rss (a page-granular high-water
    // mark that never decreases) then misattributes that one-time arena
    // growth as per-call leakage — a false positive that made this test
    // flaky on macOS (~500-768 KB of pure fragmentation). Running enough
    // warm-up iterations first lets the arenas reach steady state before
    // rss0 is sampled, so rss1 - rss0 reflects genuine per-call retention.
    // (`leaks --atExit` independently confirms 0 leaked bytes; this test's
    // job is to catch the O(N^2) retained-buffer *growth* the codegen fix
    // addressed, which would dwarf the threshold regardless.)
    w = 0
    while w < 300 {
        _wv = dirwalk.rebuild_dir(3, 5)
        if string.length(_wv) < 100 {
            println("FAIL: warm-up too short: ${string.length(_wv)}")
            exit(1)
        }
        w = w + 1
    }

    // Measure TWO consecutive loops and take the SMALLER growth. A genuine
    // per-call leak repeats in every loop (~896 KB per 1000 calls pre-fix),
    // so the minimum still carries the signal. One-time noise does not
    // repeat: under full-suite memory pressure macOS can page-compress part
    // of the process before rss0 and re-resident it inside the first loop,
    // which showed up as spurious "growth" on a leak-free run even with the
    // shim's pressure-relief sampling. That transient lands in one window,
    // not both — the min discards it.
    rss0 = getrusage_max_rss_kb()
    j = 0
    while j < 1000 {
        s = dirwalk.rebuild_dir(3, 5)
        if string.length(s) < 100 {
            println("FAIL iter ${j}: length=${string.length(s)}")
            exit(1)
        }
        j = j + 1
    }
    rss1 = getrusage_max_rss_kb()
    k = 0
    while k < 1000 {
        s2 = dirwalk.rebuild_dir(3, 5)
        if string.length(s2) < 100 {
            println("FAIL iter2 ${k}: length=${string.length(s2)}")
            exit(1)
        }
        k = k + 1
    }
    rss2 = getrusage_max_rss_kb()
    growth1 = rss1 - rss0
    growth2 = rss2 - rss1
    growth = growth1
    if growth2 < growth1 {
        growth = growth2
    }

    // Pre-fix this leaks ~896 KB across EACH 1000-iteration loop of the
    // cross-fn + recursion + bare-identifier-return shape — both windows
    // show it, so the min stays far above the bound. Post-fix both stay
    // flat (~0 KB). 256 KB threshold accommodates incidental
    // allocator-bookkeeping.
    if growth > 256 {
        println("FAIL: RSS grew ${growth1}/${growth2} KB across two 1000-call loops (min >256 KB) — cross-fn+recursion leak")
        exit(1)
    }

    println("  PASS: 2x1000 cross-fn+recursion calls, RSS growth min(${growth1}, ${growth2}) KB (bounded)")
    println("=== all cases passed ===")
}
