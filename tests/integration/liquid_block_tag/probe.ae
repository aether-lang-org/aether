// contrib.templating.liquid — Shopify's `{% liquid %}` block tag.
//
// The body is processed line-by-line as if each line were its own
// `{% line %}` tag (no braces needed). `echo EXPR` becomes `{{ EXPR }}`.
// Blank lines are ignored. `#` starts a comment line.
//
// Cases:
//   1.  Single assign inside a liquid block
//   2.  echo EXPR emits as if {{ EXPR }}
//   3.  echo with a filter chain
//   4.  Multiple assigns; later one wins
//   5.  Comments (# ...) are ignored
//   6.  Blank lines are ignored
//   7.  Mixed: assign + echo
//   8.  if/elsif/else/endif spread across lines
//   9.  for/endfor over a range, with echo inside
//   10. Capture inside a liquid block (capture/endcapture)
//   11. cycle inside a liquid block
//   12. increment inside a liquid block
//   13. Whitespace control on the outer {%- liquid -%}
//   14. Empty liquid block is a no-op

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

main() {
    // (1) Single assign.
    expect_eq(render_empty("{% liquid\n  assign x = \"hi\"\n%}{{ x }}"),
              "hi", "1 single assign")

    // (2) echo emits.
    expect_eq(render_empty("{% liquid\n  assign x = \"hello\"\n  echo x\n%}"),
              "hello", "2 echo emits")

    // (3) echo with filters.
    expect_eq(render_empty("{% liquid\n  assign x = \"hi\"\n  echo x | upcase | append:\"!\"\n%}"),
              "HI!", "3 echo + filters")

    // (4) Later assign wins.
    expect_eq(render_empty("{% liquid\n  assign x = \"first\"\n  assign x = \"second\"\n%}{{ x }}"),
              "second", "4 later assign wins")

    // (5) Comment lines ignored.
    expect_eq(render_empty("{% liquid\n  # this is a comment\n  assign x = \"ok\"\n  # another comment\n%}{{ x }}"),
              "ok", "5 # comments ignored")

    // (6) Blank lines ignored.
    expect_eq(render_empty("{% liquid\n\n\n  assign x = \"ok\"\n\n%}{{ x }}"),
              "ok", "6 blank lines ignored")

    // (7) Mixed assign + echo.
    expect_eq(render_empty("[{% liquid\n  assign x = \"A\"\n  echo x\n  assign x = \"B\"\n  echo x\n%}]"),
              "[AB]", "7 mixed assign + echo")

    // (8) if/elsif/else/endif inside a liquid block.
    expect_eq(render_empty("{% liquid\n  assign n = \"2\"\n  if n == \"1\"\n    echo \"one\"\n  elsif n == \"2\"\n    echo \"two\"\n  else\n    echo \"other\"\n  endif\n%}"),
              "two", "8 if/elsif/else inside liquid")

    // (9) for/endfor.
    expect_eq(render_empty("{% liquid\n  for i in (1..3)\n    echo i\n  endfor\n%}"),
              "123", "9 for inside liquid")

    // (10) capture/endcapture.
    expect_eq(render_empty("{% liquid\n  capture msg\n%}HELLO{% liquid\n  endcapture\n  echo msg\n%}"),
              "HELLO", "10 capture inside liquid (mixed with outer text)")

    // (11) cycle.
    expect_eq(render_empty("{% liquid\n  echo \"\" | append: \"\"\n%}{% cycle 'a','b','c' %}-{% cycle 'a','b','c' %}-{% cycle 'a','b','c' %}"),
              "a-b-c", "11 cycle outside still works after liquid block")

    // (12) increment emits its value inline (each line is a tag, and
    // increment is an emitting tag), and the counter persists across
    // the liquid-block boundary.
    expect_eq(render_empty("{% liquid\n  increment c\n  increment c\n  increment c\n%}{% increment c %}"),
              "0123", "12 increment inside liquid emits + persists")

    // (13) Whitespace control on outer liquid block.
    expect_eq(render_empty("a   {%- liquid\n  assign x = \"X\"\n-%}   {{ x }}"),
              "aX", "13 whitespace control on outer liquid")

    // (14) Empty liquid block.
    expect_eq(render_empty("a{% liquid\n%}b"),
              "ab", "14 empty liquid is no-op")

    println("All PASS")
}
