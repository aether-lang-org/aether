// std.lzf round-trip checks for text, binary payloads with embedded
// NULs, and corrupt-input handling.

import std.lzf
import std.bytes
import std.string

main() {
    print("=== std.lzf round-trip ===\n\n")

    msg = "Hello, LZF world. Repetition repetition repetition repetition repetition."
    n_in = string.length(msg)
    bound = lzf.max_compressed_size(n_in)
    if bound <= n_in {
        println("  FAIL: max bound ${bound} should exceed input ${n_in}")
        exit(1)
    }

    compressed, n_compressed, cerr = lzf.compress(msg, n_in)
    if cerr != "" {
        println("  FAIL: compress errored: ${cerr}")
        exit(1)
    }
    if n_compressed <= 0 || n_compressed > bound {
        println("  FAIL: compressed length ${n_compressed}, bound ${bound}")
        exit(1)
    }

    restored, n_restored, derr = lzf.decompress(compressed, n_compressed, n_in)
    if derr != "" {
        println("  FAIL: decompress errored: ${derr}")
        exit(1)
    }
    if n_restored != n_in || string.equals(restored, msg) != 1 {
        print("  FAIL: text round-trip mismatch\n")
        exit(1)
    }
    println("  PASS: text round-trip ${n_in} -> ${n_compressed} -> ${n_restored}")

    b = bytes.new(32)
    if b == 0 {
        print("  FAIL: bytes.new failed\n")
        exit(1)
    }
    i = 0
    while i < 32 {
        value = 0
        if i % 4 != 0 {
            value = i + 1
        }
        if bytes.set(b, i, value) != 1 {
            println("  FAIL: bytes.set failed at ${i}")
            exit(1)
        }
        i = i + 1
    }
    data = bytes.finish(b, 32)

    cb, ncb, cberr = lzf.compress(data, 32)
    if cberr != "" {
        println("  FAIL: binary compress errored: ${cberr}")
        exit(1)
    }
    ub, nub, uberr = lzf.decompress(cb, ncb, 32)
    if uberr != "" {
        println("  FAIL: binary decompress errored: ${uberr}")
        exit(1)
    }
    if nub != 32 {
        println("  FAIL: binary length ${nub}, expected 32")
        exit(1)
    }

    i = 0
    while i < 32 {
        expected = 0
        if i % 4 != 0 {
            expected = i + 1
        }
        got = string.char_at(ub, i)
        if got != expected {
            println("  FAIL: byte[${i}] got ${got}, expected ${expected}")
            exit(1)
        }
        i = i + 1
    }
    print("  PASS: binary payload with embedded NULs round-trips\n")

    _, _, short_err = lzf.decompress(cb, ncb, 31)
    if short_err == "" {
        print("  FAIL: expected short output length to fail\n")
        exit(1)
    }
    print("  PASS: short output length rejected\n")

    _, _, corrupt_err = lzf.decompress("not an lzf stream", 17, 64)
    if corrupt_err == "" {
        print("  FAIL: expected corrupt input to fail\n")
        exit(1)
    }
    print("  PASS: corrupt input rejected\n")

    empty_c, empty_nc, empty_cerr = lzf.compress("", 0)
    if empty_cerr != "" {
        println("  FAIL: empty compress errored: ${empty_cerr}")
        exit(1)
    }
    if empty_nc != 0 {
        println("  FAIL: empty compress length ${empty_nc}, expected 0")
        exit(1)
    }
    _, empty_nd, empty_derr = lzf.decompress(empty_c, empty_nc, 0)
    if empty_derr != "" {
        println("  FAIL: empty decompress errored: ${empty_derr}")
        exit(1)
    }
    if empty_nd != 0 {
        println("  FAIL: empty decompress length ${empty_nd}, expected 0")
        exit(1)
    }
    print("  PASS: empty round-trip\n")

    print("\n=== All std.lzf tests passed ===\n")
}
