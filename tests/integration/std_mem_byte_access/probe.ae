// std.mem byte-level pointer access regression test.
//
// std.mem provides get_byte / set_byte for caller-allocated raw
// pointers (vs. std.bytes which manages its own buffers). The
// driver case is the in-tree mquickjs port — every UTF-8 decoder,
// bytecode interpreter, and packed-format parser fundamentally
// does `((uint8_t*)p)[i]`. Aether parses `p[i]` syntactically but
// lowers it to `*(void*)p` which the C compiler rejects, so
// std.mem routes the same intent through a same-effect extern.
//
// This test exercises:
//   1. Round-trip: write 16 bytes via set_byte, read back via
//      get_byte. Pattern that exercises the low-byte mask
//      (`value & 0xff` in the C side, since set_byte takes int).
//   2. NULL defence on get_byte (returns -1).
//   3. NULL defence on set_byte (returns 0, no crash).
//   4. Read+write at offset 0 (boundary: not negative, not past
//      a one-byte allocation).
//   5. Round-trip through values that exceed byte range (caller
//      passes 256, 0x1ff, -1) — the C side masks to low 8 bits;
//      verify the read matches the masked value.
//   6. size_t-indexed get_byte_sz / set_byte_sz companions.

import std.mem

extern malloc(n: int) -> ptr
extern free(p: ptr)
extern exit(code: int)

main() {
    println("std.mem byte-access tests")
    println("")

    passed = 0
    failed = 0

    // Case 1: 16-byte round-trip.
    {
        p = malloc(16)
        if p == null {
            println("  [1] FAIL: malloc(16) returned null")
            failed = failed + 1
        } else {
            i = 0
            while i < 16 {
                mem.set_byte(p, i, i * 17)
                i = i + 1
            }
            ok = 1
            j = 0
            while j < 16 {
                v = mem.get_byte(p, j)
                expected = (j * 17) & 255
                if v != expected {
                    println("  [1] FAIL: at offset ${j}: got ${v}, expected ${expected}")
                    ok = 0
                    j = 16
                } else {
                    j = j + 1
                }
            }
            if ok == 1 {
                println("  [1] PASS 16-byte round-trip")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 2: NULL defence on get_byte.
    {
        v = mem.get_byte(null, 0)
        if v != -1 {
            println("  [2] FAIL: get_byte(null) should return -1, got ${v}")
            failed = failed + 1
        } else {
            println("  [2] PASS get_byte(null) returns -1")
            passed = passed + 1
        }
    }

    // Case 3: NULL defence on set_byte.
    {
        rc = mem.set_byte(null, 0, 42)
        if rc != 0 {
            println("  [3] FAIL: set_byte(null) should return 0, got ${rc}")
            failed = failed + 1
        } else {
            println("  [3] PASS set_byte(null) returns 0")
            passed = passed + 1
        }
    }

    // Case 4: single-byte allocation, boundary write+read at 0.
    {
        p = malloc(1)
        if p == null {
            println("  [4] FAIL: malloc(1) returned null")
            failed = failed + 1
        } else {
            mem.set_byte(p, 0, 0xab)
            v = mem.get_byte(p, 0)
            if v != 0xab {
                println("  [4] FAIL: single-byte round-trip got ${v}, expected 0xab")
                failed = failed + 1
            } else {
                println("  [4] PASS single-byte allocation, offset 0")
                passed = passed + 1
            }
            free(p)
        }
    }

    // Case 5: out-of-byte-range values mask to low 8 bits.
    {
        p = malloc(4)
        if p == null {
            println("  [5] FAIL: malloc(4) returned null")
            failed = failed + 1
        } else {
            // 256 → 0; 0x1ff → 0xff; -1 → 0xff (two's-complement low byte)
            mem.set_byte(p, 0, 256)
            mem.set_byte(p, 1, 0x1ff)
            mem.set_byte(p, 2, 0)
            mem.set_byte(p, 3, 255)
            v0 = mem.get_byte(p, 0)
            v1 = mem.get_byte(p, 1)
            v2 = mem.get_byte(p, 2)
            v3 = mem.get_byte(p, 3)
            ok = 1
            if v0 != 0   { println("  [5] FAIL: 256 → low 8 bits should be 0, got ${v0}");   ok = 0 }
            if v1 != 255 { println("  [5] FAIL: 0x1ff → low 8 bits should be 255, got ${v1}"); ok = 0 }
            if v2 != 0   { println("  [5] FAIL: 0 → 0, got ${v2}");                          ok = 0 }
            if v3 != 255 { println("  [5] FAIL: 255 → 255, got ${v3}");                      ok = 0 }
            if ok == 1 {
                println("  [5] PASS low-8-bit masking (256→0, 0x1ff→255, etc)")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 6: pointer get/set round-trip. Caller-allocated slot
    // big enough for a pointer; write a pointer value into it and
    // read it back. Models the FFI out-parameter pattern (`T** out`)
    // used by ported C functions like mquickjs's strstart.
    {
        slot = malloc(16)  // pointer-aligned, ample for a void*
        val = malloc(32)
        if slot == null {
            println("  [6] FAIL: malloc(slot) returned null")
            failed = failed + 1
        } else {
            if val == null {
                println("  [6] FAIL: malloc(val) returned null")
                failed = failed + 1
                free(slot)
            } else {
                rc = mem.set_ptr(slot, 0, val)
                if rc != 1 {
                    println("  [6] FAIL: set_ptr returned ${rc}, expected 1")
                    failed = failed + 1
                } else {
                    readback = mem.get_ptr(slot, 0)
                    if readback != val {
                        println("  [6] FAIL: get_ptr returned different pointer")
                        failed = failed + 1
                    } else {
                        println("  [6] PASS pointer round-trip via set_ptr/get_ptr")
                        passed = passed + 1
                    }
                }
                free(val)
                free(slot)
            }
        }
    }

    // Case 7: NULL defence on get_ptr.
    {
        v = mem.get_ptr(null, 0)
        if v != null {
            println("  [7] FAIL: get_ptr(null) should return null")
            failed = failed + 1
        } else {
            println("  [7] PASS get_ptr(null) returns null")
            passed = passed + 1
        }
    }

    // Case 8: NULL defence on set_ptr.
    {
        sentinel = malloc(8)
        rc = mem.set_ptr(null, 0, sentinel)
        if rc != 0 {
            println("  [8] FAIL: set_ptr(null) should return 0, got ${rc}")
            failed = failed + 1
        } else {
            println("  [8] PASS set_ptr(null) returns 0")
            passed = passed + 1
        }
        if sentinel != null {
            free(sentinel)
        }
    }

    // Case 9: long round-trip — write a 64-bit value via set_long,
    // read it back via get_long. Models the C-side `*(size_t*)plen`
    // write pattern used by ported C functions like mquickjs's
    // __unicode_from_utf8 with size_t* out-params.
    {
        slot = malloc(16)
        if slot == null {
            println("  [9] FAIL: malloc(slot) returned null")
            failed = failed + 1
        } else {
            rc = mem.set_long(slot, 0, 0x123456789abcdef0)
            if rc != 1 {
                println("  [9] FAIL: set_long returned ${rc}, expected 1")
                failed = failed + 1
            } else {
                v = mem.get_long(slot, 0)
                if v != 0x123456789abcdef0 {
                    println("  [9] FAIL: get_long returned ${v}, expected 0x123456789abcdef0")
                    failed = failed + 1
                } else {
                    println("  [9] PASS long round-trip via set_long/get_long")
                    passed = passed + 1
                }
            }
            free(slot)
        }
    }

    // Case 10: NULL defence on get_long / set_long.
    {
        v = mem.get_long(null, 0)
        rc = mem.set_long(null, 0, 42)
        ok = 1
        if v != 0   { println("  [10] FAIL: get_long(null) should return 0, got ${v}");  ok = 0 }
        if rc != 0  { println("  [10] FAIL: set_long(null) should return 0, got ${rc}"); ok = 0 }
        if ok == 1 {
            println("  [10] PASS get_long/set_long null defence")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 11: float<->bits round-trip. Picks a value whose
    // representation is well-known: 1.0 = 0x3ff0000000000000.
    {
        bits = mem.bits_of_float(1.0)
        if bits != 0x3ff0000000000000 {
            println("  [11] FAIL: bits_of_float(1.0) = ${bits}, expected 0x3ff0000000000000")
            failed = failed + 1
        } else {
            back = mem.float_from_bits(bits)
            if back != 1.0 {
                println("  [11] FAIL: float_from_bits round-trip != 1.0")
                failed = failed + 1
            } else {
                println("  [11] PASS float<->bits round-trip (1.0)")
                passed = passed + 1
            }
        }
    }

    // Case 12: negative-zero bit pattern. -0.0 has only the sign
    // bit set; +0.0 is all zero. Bitwise reinterpret must
    // distinguish them even though `-0.0 == 0.0` is true.
    {
        long bits_neg_zero = 0x8000000000000000  // sign bit only
        v = mem.float_from_bits(bits_neg_zero)
        bits_back = mem.bits_of_float(v)
        if bits_back != bits_neg_zero {
            println("  [12] FAIL: -0.0 bits not preserved: got ${bits_back}, expected ${bits_neg_zero}")
            failed = failed + 1
        } else {
            println("  [12] PASS negative-zero bits preserved")
            passed = passed + 1
        }
    }

    // Case 13: int round-trip — write a 32-bit value via set_int,
    // read it back via get_int. Models the C-side `*(int*)slot`
    // write pattern used by mquickjs's get_pc2line out-parameters.
    {
        slot = malloc(8)
        if slot == null {
            println("  [13] FAIL: malloc(slot) returned null")
            failed = failed + 1
        } else {
            rc = mem.set_int(slot, 0, -42)
            if rc != 1 {
                println("  [13] FAIL: set_int returned ${rc}, expected 1")
                failed = failed + 1
            } else {
                v = mem.get_int(slot, 0)
                if v != -42 {
                    println("  [13] FAIL: get_int returned ${v}, expected -42")
                    failed = failed + 1
                } else {
                    println("  [13] PASS int round-trip via set_int/get_int")
                    passed = passed + 1
                }
            }
            free(slot)
        }
    }

    // Case 14: NULL defence on get_int / set_int.
    {
        v = mem.get_int(null, 0)
        rc = mem.set_int(null, 0, 42)
        ok = 1
        if v != 0  { println("  [14] FAIL: get_int(null) should return 0, got ${v}");  ok = 0 }
        if rc != 0 { println("  [14] FAIL: set_int(null) should return 0, got ${rc}"); ok = 0 }
        if ok == 1 {
            println("  [14] PASS get_int/set_int null defence")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 15: clz32 — count leading zeros in 32-bit values.
    {
        ok = 1
        if mem.clz32(1) != 31         { println("  [15] FAIL: clz32(1) = ${mem.clz32(1)}, expected 31"); ok = 0 }
        if mem.clz32(2) != 30         { println("  [15] FAIL: clz32(2) = ${mem.clz32(2)}, expected 30"); ok = 0 }
        if mem.clz32(0xff) != 24      { println("  [15] FAIL: clz32(0xff) = ${mem.clz32(0xff)}, expected 24"); ok = 0 }
        if mem.clz32(0x80000000) != 0 { println("  [15] FAIL: clz32(2^31) != 0"); ok = 0 }
        if ok == 1 {
            println("  [15] PASS clz32 boundary values")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 16: clz64 — count leading zeros in 64-bit values.
    {
        ok = 1
        if mem.clz64(1) != 63                 { println("  [16] FAIL: clz64(1) != 63"); ok = 0 }
        if mem.clz64(0xff) != 56              { println("  [16] FAIL: clz64(0xff) != 56"); ok = 0 }
        long high = 4611686018427387904  // 2^62
        if mem.clz64(high) != 1               { println("  [16] FAIL: clz64(2^62) != 1, got ${mem.clz64(high)}"); ok = 0 }
        if ok == 1 {
            println("  [16] PASS clz64 boundary values")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 17: udiv64_32 — unsigned 64/32 division. Test cases
    // include values that would break under signed division.
    {
        ok = 1
        slot = malloc(4)
        if slot == null {
            println("  [17] FAIL: malloc failed")
            ok = 0
        } else {
            // Easy: 100 / 7 = 14 r 2
            q = mem.udiv64_32(100, 7, slot)
            r = mem.get_int(slot, 0)
            if q != 14 { println("  [17] FAIL: 100/7 quotient = ${q}, expected 14"); ok = 0 }
            if r != 2  { println("  [17] FAIL: 100/7 remainder = ${r}, expected 2"); ok = 0 }

            // High-bit case: dividend has bit 63 set.
            // 0xFFFFFFFFFFFFFFFF / 1 = same. signed long would give -1.
            // Use the bit pattern of -1 as long: that's 0xFFFFFFFFFFFFFFFF unsigned.
            q = mem.udiv64_32(-1, 1, slot)
            r = mem.get_int(slot, 0)
            // Expected: quotient 0xFFFFFFFFFFFFFFFF / 1 = 0xFFFFFFFFFFFFFFFF, low 32 = 0xFFFFFFFF = -1 as int32.
            // Remainder = 0.
            if q != -1 { println("  [17] FAIL: 0xFFFF...FFFF/1 q = ${q}, expected -1 (0xFFFFFFFF)"); ok = 0 }
            if r != 0  { println("  [17] FAIL: 0xFFFF...FFFF/1 r = ${r}, expected 0"); ok = 0 }

            // Real dtoa case: (remainder << 32) | next_limb / b
            // E.g. (0xABCDEF00 << 32 | 0x12345678) / 1000000 = ?
            // Use a known case: 0x100000000 / 256 = 0x1000000 = 16777216
            q = mem.udiv64_32(0x100000000, 256, slot)
            r = mem.get_int(slot, 0)
            if q != 0x1000000 { println("  [17] FAIL: 2^32 / 256 q = ${q}"); ok = 0 }
            if r != 0         { println("  [17] FAIL: 2^32 / 256 r = ${r}"); ok = 0 }

            free(slot)
        }
        if ok == 1 {
            println("  [17] PASS udiv64_32 quotient + remainder")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 18: udiv64_32 NULL defence.
    {
        q = mem.udiv64_32(100, 7, null)
        rc = mem.udiv64_32(100, 0, null)  // also div-by-zero
        ok = 1
        if q != 0  { println("  [18] FAIL: udiv64_32(_, _, null) returned ${q}, expected 0"); ok = 0 }
        if rc != 0 { println("  [18] FAIL: udiv64_32(_, 0, _) returned ${rc}, expected 0"); ok = 0 }
        if ok == 1 {
            println("  [18] PASS udiv64_32 null + div-by-zero defence")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 19: int8 sign extension. Write 0xff via set_int8, read
    // back via get_int8 should be -1 (sign-extended). Read same byte
    // via get_uint8 should be 255.
    {
        p = malloc(4)
        if p == null {
            println("  [19] FAIL: malloc failed")
            failed = failed + 1
        } else {
            mem.set_int8(p, 0, -1)         // stores 0xff
            mem.set_int8(p, 1, 127)
            mem.set_int8(p, 2, -128)
            mem.set_uint8(p, 3, 200)
            ok = 1
            v0s = mem.get_int8(p, 0)
            v0u = mem.get_uint8(p, 0)
            v1s = mem.get_int8(p, 1)
            v2s = mem.get_int8(p, 2)
            v3u = mem.get_uint8(p, 3)
            v3s = mem.get_int8(p, 3)
            if v0s != -1   { println("  [19] FAIL: int8(-1) sign-extend got ${v0s}");      ok = 0 }
            if v0u != 255  { println("  [19] FAIL: uint8 of same byte got ${v0u}");        ok = 0 }
            if v1s != 127  { println("  [19] FAIL: int8(127) round-trip got ${v1s}");       ok = 0 }
            if v2s != -128 { println("  [19] FAIL: int8(-128) round-trip got ${v2s}");      ok = 0 }
            if v3u != 200  { println("  [19] FAIL: uint8(200) got ${v3u}");                 ok = 0 }
            if v3s != -56  { println("  [19] FAIL: int8 of same byte (200) got ${v3s}");    ok = 0 }
            if ok == 1 {
                println("  [19] PASS int8/uint8 sign-extend & round-trip")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 20: int16/uint16 round-trip, including sign extension.
    {
        p = malloc(8)
        if p == null {
            println("  [20] FAIL: malloc failed")
            failed = failed + 1
        } else {
            mem.set_int16(p, 0, -32768)    // smallest int16
            mem.set_int16(p, 2, 32767)     // largest int16
            mem.set_uint16(p, 4, 65535)    // largest uint16
            mem.set_int16(p, 6, -1)        // sign-extends to 0xffff
            ok = 1
            v0 = mem.get_int16(p, 0)
            v1 = mem.get_int16(p, 2)
            v2 = mem.get_uint16(p, 4)
            v3s = mem.get_int16(p, 6)
            v3u = mem.get_uint16(p, 6)
            if v0 != -32768 { println("  [20] FAIL: int16 -32768 got ${v0}");  ok = 0 }
            if v1 != 32767  { println("  [20] FAIL: int16 32767 got ${v1}");   ok = 0 }
            if v2 != 65535  { println("  [20] FAIL: uint16 65535 got ${v2}");  ok = 0 }
            if v3s != -1    { println("  [20] FAIL: int16(-1) sign-extend got ${v3s}"); ok = 0 }
            if v3u != 65535 { println("  [20] FAIL: uint16 of -1 byte got ${v3u}"); ok = 0 }
            if ok == 1 {
                println("  [20] PASS int16/uint16 round-trip & sign extension")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 21: uint32 — bit pattern fits in Aether int (signed int32).
    // For values with bit 31 set, get_uint32 returns the same bit
    // pattern (so equality compares correctly), but arithmetic
    // interpretation as a signed int32 yields a negative number.
    {
        p = malloc(8)
        if p == null {
            println("  [21] FAIL: malloc failed")
            failed = failed + 1
        } else {
            // Hex literals 0x80000000 and 0xffffffff in Aether widen to long;
            // when written through set_uint32 only the low 32 bits land in
            // memory. Read back as int (signed int32) gives the negative
            // representation of the same bit pattern.
            mem.set_uint32(p, 0, 0x80000000)
            mem.set_uint32(p, 4, 0xffffffff)
            ok = 1
            v0 = mem.get_uint32(p, 0)
            v1 = mem.get_uint32(p, 4)
            // -2147483648 == int32 of 0x80000000.
            if v0 != -2147483648 { println("  [21] FAIL: uint32 0x80000000 got ${v0}"); ok = 0 }
            if v1 != -1          { println("  [21] FAIL: uint32 0xffffffff got ${v1}"); ok = 0 }
            // Cross-check via long-widened read: 0xffffffff as long is
            // 4294967295 (positive), proving the underlying bit pattern is
            // unsigned-correct even though int32 representation is negative.
            long widen = 0
            widen = mem.get_uint32(p, 4)
            // Note: assigning a negative int32 to long sign-extends in
            // Aether, so widen will still be -1 here. The unsigned
            // semantics live in the bit pattern, not the type. For
            // arithmetic that needs unsigned compare, bit-mask via
            // (widen & 0xffffffff) on the long side.
            if (widen & 0xffffffff) != 0xffffffff {
                println("  [21] FAIL: bit-mask check (widen & 0xffffffff) = ${widen & 0xffffffff}")
                ok = 0
            }
            if ok == 1 {
                println("  [21] PASS uint32 high-bit values round-trip")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 22: float32 round-trip with widening to double. 1.5 is
    // exactly representable in both float and double.
    {
        p = malloc(8)
        if p == null {
            println("  [22] FAIL: malloc failed")
            failed = failed + 1
        } else {
            mem.set_float32(p, 0, 1.5)
            mem.set_float32(p, 4, -3.25)
            ok = 1
            v0 = mem.get_float32(p, 0)
            v1 = mem.get_float32(p, 4)
            if v0 != 1.5   { println("  [22] FAIL: float32 1.5 got ${v0}");    ok = 0 }
            if v1 != -3.25 { println("  [22] FAIL: float32 -3.25 got ${v1}");  ok = 0 }
            if ok == 1 {
                println("  [22] PASS float32 round-trip (exact values)")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 23: float64 round-trip. Use 0.1 + 0.2 = 0.30000000000000004
    // (the canonical IEEE-754 example) — must preserve exactly.
    {
        p = malloc(8)
        if p == null {
            println("  [23] FAIL: malloc failed")
            failed = failed + 1
        } else {
            v_in = 0.1 + 0.2
            mem.set_float64(p, 0, v_in)
            v_out = mem.get_float64(p, 0)
            if v_out != v_in {
                println("  [23] FAIL: float64 round-trip lost precision")
                failed = failed + 1
            } else {
                println("  [23] PASS float64 round-trip exact")
                passed = passed + 1
            }
            free(p)
        }
    }

    // Case 24: NULL defence on every new sized accessor.
    {
        ok = 1
        if mem.get_int8(null, 0)    != 0 { println("  [24] FAIL: get_int8(null)"); ok = 0 }
        if mem.get_uint8(null, 0)   != 0 { println("  [24] FAIL: get_uint8(null)"); ok = 0 }
        if mem.get_int16(null, 0)   != 0 { println("  [24] FAIL: get_int16(null)"); ok = 0 }
        if mem.get_uint16(null, 0)  != 0 { println("  [24] FAIL: get_uint16(null)"); ok = 0 }
        if mem.get_uint32(null, 0)  != 0 { println("  [24] FAIL: get_uint32(null)"); ok = 0 }
        if mem.get_float32(null, 0) != 0.0 { println("  [24] FAIL: get_float32(null)"); ok = 0 }
        if mem.get_float64(null, 0) != 0.0 { println("  [24] FAIL: get_float64(null)"); ok = 0 }
        if mem.set_int8(null, 0, 1)    != 0 { println("  [24] FAIL: set_int8(null)"); ok = 0 }
        if mem.set_uint8(null, 0, 1)   != 0 { println("  [24] FAIL: set_uint8(null)"); ok = 0 }
        if mem.set_int16(null, 0, 1)   != 0 { println("  [24] FAIL: set_int16(null)"); ok = 0 }
        if mem.set_uint16(null, 0, 1)  != 0 { println("  [24] FAIL: set_uint16(null)"); ok = 0 }
        if mem.set_uint32(null, 0, 1)  != 0 { println("  [24] FAIL: set_uint32(null)"); ok = 0 }
        if mem.set_float32(null, 0, 1.0) != 0 { println("  [24] FAIL: set_float32(null)"); ok = 0 }
        if mem.set_float64(null, 0, 1.0) != 0 { println("  [24] FAIL: set_float64(null)"); ok = 0 }
        if ok == 1 {
            println("  [24] PASS NULL defence on all sized accessors")
            passed = passed + 1
        } else {
            failed = failed + 1
        }
    }

    // Case 25: typed-array-style access — same byte buffer, multiple
    // views through different sized accessors. Models the actual
    // mquickjs TypedArray load_elem dispatcher pattern: same buf,
    // class_id selects which sized read.
    {
        p = malloc(16)
        if p == null {
            println("  [25] FAIL: malloc failed")
            failed = failed + 1
        } else {
            // Write a known little-endian 64-bit pattern via set_byte.
            // 0x0123456789abcdef on little-endian: ef cd ab 89 67 45 23 01
            mem.set_byte(p,  0, 0xef)
            mem.set_byte(p,  1, 0xcd)
            mem.set_byte(p,  2, 0xab)
            mem.set_byte(p,  3, 0x89)
            mem.set_byte(p,  4, 0x67)
            mem.set_byte(p,  5, 0x45)
            mem.set_byte(p,  6, 0x23)
            mem.set_byte(p,  7, 0x01)

            // Re-read same bytes through each sized window.
            ok = 1
            // First two bytes as little-endian uint16 = 0xcdef.
            u16_lo = mem.get_uint16(p, 0)
            if u16_lo != 0xcdef { println("  [25] FAIL: get_uint16 = ${u16_lo}, expected 0xcdef"); ok = 0 }
            // First four bytes as uint32 = 0x89abcdef.  Read as int returns
            // the signed-int32 form of that bit pattern (negative); compare
            // by widening to long and masking, which preserves unsigned
            // semantics.
            long u32_lo = 0
            u32_lo = mem.get_uint32(p, 0)
            if (u32_lo & 0xffffffff) != 0x89abcdef {
                println("  [25] FAIL: get_uint32 bit pattern = ${u32_lo & 0xffffffff}, expected 0x89abcdef")
                ok = 0
            }
            // All 8 bytes as int64.
            i64 = mem.get_long(p, 0)
            if i64 != 0x0123456789abcdef { println("  [25] FAIL: get_long composite mismatch"); ok = 0 }
            if ok == 1 {
                println("  [25] PASS multi-sized read of same byte buffer")
                passed = passed + 1
            } else {
                failed = failed + 1
            }
            free(p)
        }
    }

    // Case 26: size_t-indexed byte get/set companions.
    {
        p = malloc(8)
        if p == null {
            println("  [26] FAIL: malloc(8) returned null")
            failed = failed + 1
        } else {
            size_t idx = 5
            rc = mem.set_byte_sz(p, idx, 0x1ab)
            v = mem.get_byte_sz(p, idx)
            if rc != 1 || v != 0xab {
                println("  [26] FAIL: get/set_byte_sz rc=${rc}, value=${v}, expected 171")
                failed = failed + 1
            } else {
                println("  [26] PASS size_t-indexed byte round-trip")
                passed = passed + 1
            }
            free(p)
        }
    }

    println("")
    println("std_mem_byte_access: ${passed} passing, ${failed} failing (of 26)")
    if failed > 0 {
        exit(1)
    }
    exit(0)
}
