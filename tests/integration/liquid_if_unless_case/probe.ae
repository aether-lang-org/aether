// contrib.templating.liquid — `{% if %}` / `{% elsif %}` / `{% else %}`
// / `{% endif %}`, `{% unless %}` / `{% endunless %}`, and
// `{% case %}` / `{% when %}` / `{% else %}` / `{% endcase %}`.
//
// Truthiness rules (string-only context, this slice):
//   - Keywords `nil` / `null` / `false` / `empty` / `blank` are falsy
//   - Keyword `true` is truthy
//   - Bound variable is truthy when its string value is non-empty
//   - Unbound variable resolves to "" -> falsy
//   - Quoted string literal is truthy when non-empty
//
// Operators: == != < > <= >= contains, with `and` / `or` connectives.
// Flat left-to-right grammar: `a and b or c` = `((a and b) or c)`.
//
// Cases:
//   1.  if true branch on a bound non-empty var
//   2.  if false branch when var is unbound
//   3.  if with explicit `true` keyword
//   4.  if with explicit `false` keyword
//   5.  if + else
//   6.  if + elsif + else (elsif wins)
//   7.  if + elsif + else (else wins)
//   8.  Equality: a == b on string values
//   9.  Inequality: a != b
//   10. Ordering on int-encoded strings: x > "5"
//   11. `contains` substring
//   12. `and` short-circuit semantics (both branches needed)
//   13. `or` semantics
//   14. `a and b or c` = `((a and b) or c)`
//   15. Nested if inside if (true outer, true inner)
//   16. Nested if inside if (true outer, false inner falls to outer else)
//   17. unless with truthy condition (no output)
//   18. unless with falsy condition (output)
//   19. unless + else
//   20. case/when picks the matching branch
//   21. case/when with `when "a", "b"` matches either
//   22. case/when else when no when matches
//   23. case/when first match wins (no fallthrough)
//   24. Whitespace control around if works (no leftover blank lines)
//   25. Unmatched `{% if %}` -> render error
//   26. Stray `{% endif %}` -> render error
//   27. if uses captured variable from preceding {% capture %}

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_with(src: string, key: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, key, val)
    out, _ = liquid.render(t, ctx)
    return out
}

render_empty(src: string) -> string {
    t, _ = liquid.parse_string(src)
    out, _ = liquid.render(t, liquid.context_new())
    return out
}

main() {
    // (1) Truthy var -> body emitted.
    expect_eq(render_with("{% if name %}YES{% endif %}", "name", "alice"),
              "YES", "1 if true branch on bound var")

    // (2) Unbound var -> body skipped.
    expect_eq(render_empty("[{% if missing %}YES{% endif %}]"),
              "[]", "2 if false on unbound var")

    // (3) Keyword `true`.
    expect_eq(render_empty("{% if true %}A{% endif %}"), "A", "3 if true literal")

    // (4) Keyword `false`.
    expect_eq(render_empty("[{% if false %}A{% endif %}]"), "[]",
              "4 if false literal")

    // (5) else branch.
    expect_eq(render_empty("{% if false %}A{% else %}B{% endif %}"),
              "B", "5 if/else")

    // (6) elsif wins.
    expect_eq(render_empty("{% if false %}A{% elsif true %}B{% else %}C{% endif %}"),
              "B", "6 elsif wins")

    // (7) else wins.
    expect_eq(render_empty("{% if false %}A{% elsif false %}B{% else %}C{% endif %}"),
              "C", "7 else wins")

    // (8) Equality.
    expect_eq(render_with("{% if name == \"alice\" %}HI{% else %}NO{% endif %}",
                          "name", "alice"),
              "HI", "8 equality true")

    // (9) Inequality.
    expect_eq(render_with("{% if name != \"bob\" %}HI{% else %}NO{% endif %}",
                          "name", "alice"),
              "HI", "9 inequality")

    // (10) Ordering on numeric strings.
    expect_eq(render_with("{% if x > \"5\" %}BIG{% else %}small{% endif %}",
                          "x", "10"),
              "BIG", "10 ordering int")

    // (11) `contains` substring.
    expect_eq(render_with("{% if name contains \"li\" %}Y{% endif %}",
                          "name", "alice"),
              "Y", "11 contains")

    // (12) `and`: both must hold.
    expect_eq(render_with("{% if name and tag %}Y{% else %}N{% endif %}",
                          "name", "alice"),
              "N", "12a and both required (tag unbound)")

    // (13) `or`: either suffices.
    expect_eq(render_with("{% if missing or name %}Y{% else %}N{% endif %}",
                          "name", "alice"),
              "Y", "13 or one suffices")

    // (14) Flat left-to-right: `a and b or c` = `(a and b) or c`.
    //   With name truthy, tag falsy, fallback truthy: (T and F) or T = T
    expect_eq(render_empty("{% assign name = \"alice\" %}{% assign fallback = \"x\" %}{% if name and tag or fallback %}Y{% else %}N{% endif %}"),
              "Y", "14 a and b or c flat")

    // (15) Nested if-in-if, both true.
    expect_eq(render_empty("{% if true %}{% if true %}YES{% endif %}{% endif %}"),
              "YES", "15 nested true/true")

    // (16) Nested if-in-if, outer true / inner false / outer else does
    //   NOT cover inner-else absence (the inner-if just emits nothing).
    expect_eq(render_empty("[{% if true %}{% if false %}A{% endif %}B{% else %}C{% endif %}]"),
              "[B]", "16 nested outer-T inner-F still falls to outer body")

    // (17) unless truthy -> skip.
    expect_eq(render_with("[{% unless name %}HIDDEN{% endunless %}]",
                          "name", "alice"),
              "[]", "17 unless truthy skips")

    // (18) unless falsy -> emit.
    expect_eq(render_empty("[{% unless missing %}SHOWN{% endunless %}]"),
              "[SHOWN]", "18 unless falsy emits")

    // (19) unless + else.
    expect_eq(render_with("{% unless name %}A{% else %}B{% endunless %}",
                          "name", "alice"),
              "B", "19 unless else branch")

    // (20) case/when matches.
    expect_eq(render_with("{% case x %}{% when \"1\" %}ONE{% when \"2\" %}TWO{% else %}OTHER{% endcase %}",
                          "x", "2"),
              "TWO", "20 case/when match")

    // (21) case/when with multiple alternatives.
    expect_eq(render_with("{% case x %}{% when \"a\", \"b\", \"c\" %}LO{% when \"X\" %}HI{% endcase %}",
                          "x", "b"),
              "LO", "21 case multi-alternative")

    // (22) case/when falls through to else.
    expect_eq(render_with("{% case x %}{% when \"1\" %}A{% else %}DEFAULT{% endcase %}",
                          "x", "99"),
              "DEFAULT", "22 case else")

    // (23) First match wins (no fallthrough).
    expect_eq(render_with("{% case x %}{% when \"a\" %}FIRST{% when \"a\" %}SECOND{% endcase %}",
                          "x", "a"),
              "FIRST", "23 case first match wins")

    // (24) Whitespace control trims around the block.
    expect_eq(render_empty("a   {%- if true -%}   X   {%- endif -%}   b"),
              "aXb", "24 whitespace control around if")

    // (25) Unmatched if.
    t25, _ = liquid.parse_string("a {% if true %}b no end")
    _, e25 = liquid.render(t25, liquid.context_new())
    if string.equals(e25, "") == 1 {
        println("FAIL 25 unmatched if: expected error")
        exit(1)
    }
    println("PASS 25 unmatched if: '${e25}'")

    // (26) Stray endif.
    t26, _ = liquid.parse_string("ok {% endif %}")
    _, e26 = liquid.render(t26, liquid.context_new())
    if string.equals(e26, "") == 1 {
        println("FAIL 26 stray endif: expected error")
        exit(1)
    }
    println("PASS 26 stray endif: '${e26}'")

    // (27) if reads a {% capture %}-bound name.
    expect_eq(render_empty("{% capture s %}set{% endcapture %}{% if s == \"set\" %}HIT{% endif %}"),
              "HIT", "27 if sees captured var")

    println("All PASS")
}
