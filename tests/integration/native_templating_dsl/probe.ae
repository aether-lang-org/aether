// contrib.templating.native — builder DSL smoke test.
//
// What this exercises:
//   1. render_html() { tag("p") { text("...") } } — the basic shape.
//   2. Nested tags compose correctly.
//   3. HTML metacharacters in text() get escaped.
//   4. raw() bypasses escaping.
//   5. for-loop inside a tag's block emits one tag per iteration.
//   6. Aether ${...} interpolation flows through text() and gets escaped.
//
// Note the `render_html()` PARENS: trailing blocks in Aether attach only
// to call sites, never to bare function references. The parser-level
// rule is the same one you'd use in Groovy or Kotlin.

import contrib.templating.native
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

main() {
    // (1) Basic tag wrap.
    out1 = native.render_html() {
        native.tag("p") { native.text("hello") }
    }
    expect_eq(out1, "<p>hello</p>", "1 basic tag wrap")

    // (2) Nested tags compose.
    out2 = native.render_html() {
        native.tag("div") {
            native.tag("span") { native.text("deep") }
        }
    }
    expect_eq(out2, "<div><span>deep</span></div>", "2 nested tags")

    // (3) text() HTML-escapes the five canonical metas.
    out3 = native.render_html() {
        native.tag("a") { native.text("<x&y>'q\"") }
    }
    expect_eq(out3, "<a>&lt;x&amp;y&gt;&#39;q&quot;</a>", "3 text escapes")

    // (4) raw() bypasses escaping (trusted markup).
    out4 = native.render_html() {
        native.raw("<br>")
    }
    expect_eq(out4, "<br>", "4 raw bypasses")

    // (5) for-loop inside a tag's block — the actual pitch. Each
    //     iteration's body runs against the SAME enclosing tag's
    //     emitter (the `for` is a real Aether statement, not a
    //     template-language reimplementation).
    items = ["alpha", "beta", "<gamma>"]
    out5 = native.render_html() {
        native.tag("ul") {
            for i in 0..3 {
                native.tag("li") { native.text(items[i]) }
            }
        }
    }
    expect_eq(out5,
              "<ul><li>alpha</li><li>beta</li><li>&lt;gamma&gt;</li></ul>",
              "5 for loop inside tag block")

    // (6) Aether ${...} interpolation: a captured user value with HTML
    //     metas, interpolated into a literal, then handed to text() —
    //     the result is escape-correct because the captured-and-
    //     interpolated string still flows through text().
    user_name = "Alice <script>"
    out6 = native.render_html() {
        native.tag("p") { native.text("Hello ${user_name}") }
    }
    expect_eq(out6, "<p>Hello Alice &lt;script&gt;</p>",
              "6 interp escapes captured user value")

    println("All PASS")
}
