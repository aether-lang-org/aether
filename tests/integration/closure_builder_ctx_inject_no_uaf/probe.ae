// Regression for Part 2 of the closure-env-freed UAF.
//
// Shape: cross-module visible-body wrapper whose first param is `_ctx:
// ptr`. The caller omits _ctx (codegen injects `_aether_ctx_get()` at
// position 0), so the closure arg's AST position is one less than its
// position in the wrapper's declared params. Pre-fix, the call-site
// drain gate checked escape against the wrong param (label, not
// on_press), got a false-non-escape verdict, and emitted
// `free(_ad_0.env)` after the call → the C side later read the freed
// env (UAF).
import uikit (register_btn)
extern fire_btn()

main() {
    msg = "ok"
    inner = |d: int| { println(msg) }
    // No `_ctx` arg → codegen injects ctx → drain gate must map
    // AST arg idx 1 (the callback) → param idx 2 (on_press).
    register_btn("=") callback { call(inner, 7) }
    fire_btn()
    return 0
}
