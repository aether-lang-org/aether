// contrib.templating.liquid — integer-math + HTML / slice filters.
//
// Cases:
//   1.  plus on a stringified int
//   2.  minus
//   3.  times
//   4.  divided_by truncates toward zero
//   5.  divided_by:0 -> render error
//   6.  modulo
//   7.  modulo:0 -> render error
//   8.  at_least clamps up
//   9.  at_least leaves higher value alone
//   10. at_most clamps down
//   11. at_most leaves lower value alone
//   12. plus on an empty/unbound var coerces to 0
//   13. Chain plus | times | minus stays integer
//   14. strip_html drops `<...>` runs
//   15. strip_html on unterminated `<` swallows to end
//   16. strip_newlines drops every \r and \n
//   17. slice:"start" returns one byte
//   18. slice:"start","len" returns len bytes
//   19. slice with negative start counts from the end
//   20. slice past the end is clamped
//   21. slice:"0","-1" returns empty (negative len)

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_eq(actual: string, want: string, label: string) {
    if string.equals(actual, want) != 1 {
        println("FAIL ${label}: got '${actual}' want '${want}'")
        exit(1)
    }
    println("PASS ${label}: '${actual}'")
}

render_x(src: string, val: string) -> string {
    t, _ = liquid.parse_string(src)
    ctx = liquid.context_new()
    liquid.context_put_string(ctx, "x", val)
    out, _ = liquid.render(t, ctx)
    return out
}

main() {
    // (1) plus
    expect_eq(render_x("{{ x | plus:\"3\" }}", "10"), "13", "1 plus")
    // (2) minus
    expect_eq(render_x("{{ x | minus:\"4\" }}", "10"), "6", "2 minus")
    // (3) times
    expect_eq(render_x("{{ x | times:\"5\" }}", "6"), "30", "3 times")
    // (4) divided_by truncates toward zero
    expect_eq(render_x("{{ x | divided_by:\"3\" }}", "10"), "3", "4 divided_by truncates")

    // (5) divided_by:0 errors
    t5, _ = liquid.parse_string("{{ x | divided_by:\"0\" }}")
    ctx5 = liquid.context_new()
    liquid.context_put_string(ctx5, "x", "10")
    _, e5 = liquid.render(t5, ctx5)
    if string.equals(e5, "") == 1 {
        println("FAIL 5 divided_by:0: expected error")
        exit(1)
    }
    println("PASS 5 divided_by:0: '${e5}'")

    // (6) modulo
    expect_eq(render_x("{{ x | modulo:\"3\" }}", "10"), "1", "6 modulo")

    // (7) modulo:0 errors
    t7, _ = liquid.parse_string("{{ x | modulo:\"0\" }}")
    ctx7 = liquid.context_new()
    liquid.context_put_string(ctx7, "x", "10")
    _, e7 = liquid.render(t7, ctx7)
    if string.equals(e7, "") == 1 {
        println("FAIL 7 modulo:0: expected error")
        exit(1)
    }
    println("PASS 7 modulo:0: '${e7}'")

    // (8) at_least clamps up
    expect_eq(render_x("{{ x | at_least:\"10\" }}", "3"), "10", "8 at_least clamps")
    // (9) at_least leaves higher alone
    expect_eq(render_x("{{ x | at_least:\"10\" }}", "20"), "20", "9 at_least identity")
    // (10) at_most clamps down
    expect_eq(render_x("{{ x | at_most:\"10\" }}", "20"), "10", "10 at_most clamps")
    // (11) at_most leaves lower alone
    expect_eq(render_x("{{ x | at_most:\"10\" }}", "3"), "3", "11 at_most identity")

    // (12) plus on empty value -> 0 + N
    expect_eq(render_x("{{ x | plus:\"7\" }}", ""), "7", "12 plus on empty")

    // (13) chain stays integer
    expect_eq(render_x("{{ x | plus:\"3\" | times:\"2\" | minus:\"1\" }}", "5"),
              "15", "13 chain plus|times|minus")

    // (14) strip_html drops tags
    expect_eq(render_x("{{ x | strip_html }}", "a<b>bold</b>c<br/>d"),
              "aboldcd", "14 strip_html")

    // (15) strip_html unterminated `<` swallows
    expect_eq(render_x("{{ x | strip_html }}", "ok<oops"),
              "ok", "15 strip_html unterminated")

    // (16) strip_newlines drops \r and \n
    expect_eq(render_x("{{ x | strip_newlines }}", "a\nb\r\nc\rd"),
              "abcd", "16 strip_newlines")

    // (17) slice:"start" returns 1 byte
    expect_eq(render_x("{{ x | slice:\"1\" }}", "abcdef"),
              "b", "17 slice 1-arg")

    // (18) slice:"start","len"
    expect_eq(render_x("{{ x | slice:\"1\",\"3\" }}", "abcdef"),
              "bcd", "18 slice 2-arg")

    // (19) negative start
    expect_eq(render_x("{{ x | slice:\"-2\",\"2\" }}", "abcdef"),
              "ef", "19 slice negative start")

    // (20) past-end clamp
    expect_eq(render_x("{{ x | slice:\"4\",\"10\" }}", "abcdef"),
              "ef", "20 slice past-end clamp")

    // (21) negative len
    expect_eq(render_x("{{ x | slice:\"0\",\"-1\" }}", "abcdef"),
              "", "21 slice negative len")

    println("All PASS")
}
