// Validate contrib.cryptography.rsa OAEP + PSS (RFC 8017, SHA-256) against
// python-generated reference vectors on a fixed RSA-1024 key, plus round-trips.
import contrib.cryptography.rsa
import std.bignum
import std.bytes
import std.string
import std.io

hv(c: int) -> int { if c>=48 { if c<=57 { return c-48 } } if c>=97 { if c<=102 { return c-87 } } return 0 }
// odd-length-safe hex decode (leading implicit zero nibble)
hb(h: string) -> ptr {
    n = string.length(h)
    nb = (n + 1) / 2
    b = bytes.new(nb)
    z = 0
    while z < nb { bytes.set(b, z, 0); z = z + 1 }
    // process from the right so an odd leading nibble lands in byte 0
    i = n - 1
    bi = nb - 1
    while i >= 0 {
        lo = hv(string_char_at_n(h, n, i))
        hi = 0
        if i - 1 >= 0 { hi = hv(string_char_at_n(h, n, i - 1)) }
        bytes.set(b, bi, hi * 16 + lo)
        bi = bi - 1
        i = i - 2
    }
    return b
}
bh(b: ptr) -> string { d="0123456789abcdef"; o=""; n=bytes.length(b); i=0; while i<n { v=bytes.get(b,i); o=string.concat(o,string.concat(string.substring(d,(v/16)&15,((v/16)&15)+1),string.substring(d,v&15,(v&15)+1))); i=i+1 } return o }
bnhex(h: string) -> ptr { b=hb(h); n=bignum.from_bytes_unsigned(b, bytes.length(b)); bytes.free(b); return n }
ck(lbl: string, got: string, want: string) -> int { if got==want { println("ok   ${lbl}"); return 0 } println("FAIL ${lbl}"); println("  got:  ${got}"); println("  want: ${want}"); return 1 }

main() {
    fails = 0
    n = bnhex("cfc733d3d62af11a935cbba777e3bf08262629284d84095aecf7dfc63efe38dd0680a6972d677ff04cc3d2e7c84cb4463c528ebc87680623db37792f0315447b2a5da8d229afa229af95b5249eba3c4b3ea726f54989b76cca9002ee10a383de28efe84ebc6f5b74e9f201fd1b9543679e4ef022bf728270b9687beb10599d55"); e = bnhex("10001"); d = bnhex("7f6fea75cf31df573172fb15a80ee3a817dde7f87432bb9a2d258af688c45c14145cebd06564c9af9525b641bb34708d738a1f49bab32eb0e74f8ae02ebfe893976a220e1b8df88445fb1e9c2fe4f11fd8c6cd42fef697c22bf3c2dd9dab6333aef9b1cb4dc7dd4c371015f103d36561a5ce65f4ac5055403301a94c920f1401")
    k = rsa.key_from_components(n, e, d)

    // OAEP encrypt (fixed seed) + decrypt
    seed = hb("000102030405060708090a0b0c0d0e0f101112131415161718191a1b1c1d1e1f"); msg = hb("68656c6c6f206f616570")
    fails = fails + ck("oaep encrypt", bh(rsa.encrypt_oaep(k, msg, bytes.length(msg), seed)), "b07ad49540cd08de66247b1a8c28070ed013a6bfee2750bb76b28bb575af5fa6af3f88c5366f20c63da1990cd72263acf635a90cc77b1a8445d66ada0374c8b6b0401f940174df0194d883ec29bc93aecc99c0c17ea259d270b864d5b6dde614e6466bb32dbd6901f8fa6e6816b7ee6d8cf02a8a3fc63501a5a25e2d0c07fb5e")
    pt, oerr = rsa.decrypt_oaep(k, hb("b07ad49540cd08de66247b1a8c28070ed013a6bfee2750bb76b28bb575af5fa6af3f88c5366f20c63da1990cd72263acf635a90cc77b1a8445d66ada0374c8b6b0401f940174df0194d883ec29bc93aecc99c0c17ea259d270b864d5b6dde614e6466bb32dbd6901f8fa6e6816b7ee6d8cf02a8a3fc63501a5a25e2d0c07fb5e"))
    if oerr != "" { println("FAIL oaep decrypt: ${oerr}"); fails = fails + 1 }
    fails = fails + ck("oaep decrypt", bh(pt), "68656c6c6f206f616570")

    // PSS sign (fixed salt) + verify
    mh = hb("5d1961d33b1b26035f275173addb3ed49f4f1912bf9b8ea2bcb6df88480c5057"); salt = hb("404142434445464748494a4b4c4d4e4f505152535455565758595a5b5c5d5e5f")
    fails = fails + ck("pss sign", bh(rsa.sign_pss(k, mh, salt, bytes.length(salt))), "cad326f8644bb81fdf7696a1100e0ea9b7f630d24a724874eb98048294d6e182c6bffd71600de9a58679ad027bf76429818d3376323743aedb9c46d0bc914866c36ae5f57d4aa9ad52f1adb2e076179ec16d66a9c5de12ab195c27c1afcee8ca1deb8785dfc5d722a7abe5c014be04c247b0d1f53ce026cf3dffdbc0e9051ca1")
    if rsa.verify_pss(k, mh, hb("cad326f8644bb81fdf7696a1100e0ea9b7f630d24a724874eb98048294d6e182c6bffd71600de9a58679ad027bf76429818d3376323743aedb9c46d0bc914866c36ae5f57d4aa9ad52f1adb2e076179ec16d66a9c5de12ab195c27c1afcee8ca1deb8785dfc5d722a7abe5c014be04c247b0d1f53ce026cf3dffdbc0e9051ca1"), 32) != 1 { println("FAIL pss verify"); fails = fails + 1 } else { println("ok   pss verify") }

    // round-trips on fresh inputs
    rt = hb("00112233445566778899aabbccddeeff")
    rtct = rsa.encrypt_oaep(k, rt, bytes.length(rt), seed)
    rtpt, rerr = rsa.decrypt_oaep(k, rtct)
    if rerr != "" || bh(rtpt) != bh(rt) { println("FAIL oaep round-trip"); fails = fails + 1 } else { println("ok   oaep round-trip") }
    rsig = rsa.sign_pss(k, mh, salt, 32)
    if rsa.verify_pss(k, mh, rsig, 32) != 1 { println("FAIL pss round-trip"); fails = fails + 1 } else { println("ok   pss round-trip") }

    if fails == 0 { println("ALL PASS"); return }
    println("FAILURES"); exit(1)
}
