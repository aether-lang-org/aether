// contrib.templating.liquid — lex error messages include `at line N`.
//
// The lexer emits four kinds of `unterminated` errors. Each one now
// names the line on which the offending delimiter opened, so users can
// pinpoint the issue in long templates.
//
// Cases:
//   1.  Unterminated `{{` on line 1
//   2.  Unterminated `{{` on line 3 (after two newlines)
//   3.  Unterminated `{%` on line 1
//   4.  Unterminated `{%` on line 5
//   5.  Unterminated `{% comment %}` — line of the opening `{% comment`
//   6.  Unterminated `{% raw %}` — line of the opening `{% raw`
//   7.  Line count uses `\n` only (CRLF \r\n still increments by 1 per \n)
//   8.  Error text contains `at line` substring for forward-compat

import contrib.templating.liquid
import std.string

extern exit(code: int)

expect_contains(haystack: string, needle: string, label: string) {
    if string.contains(haystack, needle) == 0 {
        println("FAIL ${label}: got '${haystack}' did not contain '${needle}'")
        exit(1)
    }
    println("PASS ${label}: '${haystack}'")
}

main() {
    // (1) Unterminated `{{` on line 1.
    _, e1 = liquid.parse_string("{{ x")
    expect_contains(e1, "at line 1", "1 `{{` on line 1")

    // (2) Unterminated `{{` on line 3.
    src2 = "ok line 1\nok line 2\n{{ x"
    _, e2 = liquid.parse_string(src2)
    expect_contains(e2, "at line 3", "2 `{{` on line 3")

    // (3) Unterminated `{%` on line 1.
    _, e3 = liquid.parse_string("{% if x")
    expect_contains(e3, "at line 1", "3 `{%` on line 1")

    // (4) Unterminated `{%` on line 5.
    src4 = "l1\nl2\nl3\nl4\n{% if x"
    _, e4 = liquid.parse_string(src4)
    expect_contains(e4, "at line 5", "4 `{%` on line 5")

    // (5) Unterminated `{% comment %}`.
    src5 = "head\n{% comment %}\nnever closed"
    _, e5 = liquid.parse_string(src5)
    expect_contains(e5, "comment", "5 comment error mentions comment")
    expect_contains(e5, "at line 2", "5b comment error line 2")

    // (6) Unterminated `{% raw %}`.
    src6 = "x\ny\n{% raw %}\nbody never closed"
    _, e6 = liquid.parse_string(src6)
    expect_contains(e6, "raw", "6 raw error mentions raw")
    expect_contains(e6, "at line 3", "6b raw error line 3")

    // (7) CRLF: `\n` is the line bumper. Inserting `\r` doesn't
    // change the count.
    src7 = "l1\r\nl2\r\n{{ x"
    _, e7 = liquid.parse_string(src7)
    expect_contains(e7, "at line 3", "7 CRLF still counts \\n only")

    // (8) The exact substring `at line` appears regardless of variant.
    _, e8 = liquid.parse_string("{% if y")
    expect_contains(e8, "at line ", "8 `at line` substring present")

    println("All PASS")
}
