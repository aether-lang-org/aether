// Validate contrib.cryptography.aes AES-GCM against NIST SP800-38D vectors
// (test cases 1, 2, 4) plus open round-trip + tamper rejection.
import contrib.cryptography.aes
import std.bytes
import std.string
import std.io

hv(c: int) -> int { if c>=48 { if c<=57 { return c-48 } } if c>=97 { if c<=102 { return c-87 } } return 0 }
hb(h: string) -> ptr { n=string.length(h); b=bytes.new(n/2); i=0; while i<n { bytes.set(b,i/2,hv(string_char_at_n(h,n,i))*16+hv(string_char_at_n(h,n,i+1))); i=i+2 } return b }
bh(b: ptr) -> string { d="0123456789abcdef"; o=""; n=bytes.length(b); i=0; while i<n { v=bytes.get(b,i); o=string.concat(o,string.concat(string.substring(d,(v/16)&15,((v/16)&15)+1),string.substring(d,v&15,(v&15)+1))); i=i+1 } return o }
ck(lbl: string, got: string, want: string) -> int { if got==want { println("ok   ${lbl}"); return 0 } println("FAIL ${lbl}"); println("  got:  ${got}"); println("  want: ${want}"); return 1 }

main() {
    fails = 0
    empty = bytes.new(0)

    // Case 1: zero key/IV, empty AAD+PT -> tag only
    k1 = hb("00000000000000000000000000000000")
    iv0 = hb("000000000000000000000000")
    e1 = aes.new_encryptor(k1, 16)
    fails = fails + ck("case1 tag", bh(aes.gcm_seal(e1, iv0, empty, 0, empty, 0)),
        "58e2fccefa7e3061367f1d57a4e7455a")

    // Case 2: zero key/IV, PT = 16 zero bytes
    pt2 = hb("00000000000000000000000000000000")
    fails = fails + ck("case2 ct+tag", bh(aes.gcm_seal(e1, iv0, empty, 0, pt2, 16)),
        "0388dace60b6a392f328c2b971b2fe78ab6e47d42cec13bdf53a67b21257bddf")

    // Case 4: with AAD
    k4 = hb("feffe9928665731c6d6a8f9467308308")
    iv4 = hb("cafebabefacedbaddecaf888")
    aad = hb("feedfacedeadbeeffeedfacedeadbeefabaddad2")
    pt4 = hb("d9313225f88406e5a55909c5aff5269a86a7a9531534f7da2e4c303d8a318a721c3c0c95956809532fcf0e2449a6b525b16aedf5aa0de657ba637b39")
    e4 = aes.new_encryptor(k4, 16)
    sealed = aes.gcm_seal(e4, iv4, aad, bytes.length(aad), pt4, bytes.length(pt4))
    fails = fails + ck("case4 ct+tag", bh(sealed),
        "42831ec2217774244b7221b784d0d49ce3aa212f2c02a4e035c17e2329aca12e21d514b25466931c7d8f6a5aac84aa051ba30b396a0aac973d58e0915bc94fbc3221a5db94fae95ae7121a47")

    // open round-trip
    op, err = aes.gcm_open(e4, iv4, aad, bytes.length(aad), sealed, bytes.length(sealed))
    if err != "" { println("FAIL open: ${err}"); fails = fails + 1 }
    if bh(op) != bh(pt4) { println("FAIL open roundtrip"); fails = fails + 1 } else { println("ok   open roundtrip") }
    // tamper
    bytes.set(sealed, 0, bytes.get(sealed, 0) ^ 1)
    _, terr = aes.gcm_open(e4, iv4, aad, bytes.length(aad), sealed, bytes.length(sealed))
    if terr == "" { println("FAIL tamper not rejected"); fails = fails + 1 } else { println("ok   tamper rejected") }

    if fails == 0 { println("ALL PASS"); return }
    println("FAILURES"); exit(1)
}
