// Regression test for `io.stderr_write` and `io.stdout_write`.
//
// These are unbuffered fd-1 / fd-2 writes for crash-trace paths
// where stdio buffering would lose output before the process aborts.
//
// API note: both take just `data: string` — the byte count comes
// from the string itself (string.length, AetherString-aware). The
// former (data, length) two-arg form was removed: `string` already
// carries its length, so a caller-supplied count was redundant.
//
// What this test guards:
//   1. Functions exist, are callable, return >= 0 byte counts.
//   2. The byte count returned matches the string's own length on a
//      well-formed write.
//   3. An empty string writes 0 bytes (no crash).

import std.io
import std.string

extern exit(code: int)

main() {
    println("=== io.stderr_write / io.stdout_write smoke ===")

    // Case 1: simple write to stdout — count comes from the string.
    msg = "hello stdout\n"
    n = io.stdout_write(msg)
    if n != string.length(msg) {
        println("FAIL 1: stdout_write returned ${n}, expected ${string.length(msg)}")
        exit(1)
    }
    println("  PASS 1: stdout_write returns the string's byte count")

    // Case 2: simple write to stderr.
    err = "hello stderr\n"
    en = io.stderr_write(err)
    if en != string.length(err) {
        println("FAIL 2: stderr_write returned ${en}, expected ${string.length(err)}")
        exit(1)
    }
    println("  PASS 2: stderr_write returns the string's byte count")

    // Case 3: empty string writes nothing (no crash, returns 0).
    z = io.stdout_write("")
    if z != 0 {
        println("FAIL 3: stdout_write(\"\") = ${z}, expected 0")
        exit(1)
    }
    println("  PASS 3: empty-string write is a no-op (returns 0)")

    println("=== All cases passed ===")
}
