// Regression (#749 Ask C): the `longdouble` primitive — C `long double`,
// the widest numeric. Gates aedis INCRBYFLOAT / sorted-set score
// conversion / object.c getLongDoubleFromObject / util.c number
// formatting, which need exact `long double` semantics.
//
// Covers: longdouble params + return, int->longdouble and
// float(double)->longdouble widening, arithmetic (longdouble op
// longdouble, longdouble op int promotes to longdouble), comparison,
// a longdouble struct field, and ${} interpolation (%Lg) + println.
// Asserted via int-comparable checks + exit(1) on mismatch.

extern exit(code: int)

struct Acc { total: longdouble  count: int }

widen(n: int) -> longdouble { return n }        // int -> long double
from_f(f: float) -> longdouble { return f }     // double -> long double
ld_add(a: longdouble, b: longdouble) -> longdouble { return a + b }

// longdouble -> int narrowing on return (C conversion).
trunc_to_int(x: longdouble) -> int { return x }

main() {
    println("=== test_longdouble ===")

    x = widen(10)
    y = from_f(2.5)
    sum = ld_add(x, y)              // 12.5
    scaled = x * 3                  // long double * int -> 30.0

    if trunc_to_int(sum) != 12      { println("FAIL: sum (got ${sum})"); exit(1) }
    if trunc_to_int(scaled) != 30   { println("FAIL: scaled (got ${scaled})"); exit(1) }
    if (sum > x) == false           { println("FAIL: comparison sum>x"); exit(1) }
    if (x > sum) == true            { println("FAIL: comparison x>sum"); exit(1) }

    a = Acc { total: sum, count: 2 }
    if trunc_to_int(a.total) != 12  { println("FAIL: struct field"); exit(1) }
    if a.count != 2                 { println("FAIL: struct sibling field"); exit(1) }

    println("  sum=${sum} scaled=${scaled} field=${a.total}")
    println("  PASS: longdouble arithmetic / widening / struct field")
    println("OK")
}
