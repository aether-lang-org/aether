// std.audio v1 regression — WAV decode + playback transport over the null
// backend (deterministic, no sound card). The WAV is BUILT in-test via
// std.bytes so there is no binary fixture to commit; a known set of 16-bit
// samples lets us assert decode correctness (frame count, duration, channel
// layout), then the transport/seek/volume/position surface is exercised.

import std.audio
import std.bytes
import std.string

extern exit(code: int)

fn ck(cond: bool, msg: string) -> int {
    if !cond { println("FAIL: ${msg}"); return 1 }
    return 0
}

// Build a canonical 16-bit PCM WAV: `frames` frames, `ch` channels,
// `rate` Hz, every sample set to `sample16` (a signed 16-bit value).
// Returns (wav_bytes, total_length).
fn make_wav(frames: int, ch: int, rate: int, sample16: int) -> (string, int) {
    data_bytes = frames * ch * 2         // 16-bit
    total = 44 + data_bytes
    b = bytes.new(total)
    // RIFF header
    bytes.set(b, 0, 82); bytes.set(b, 1, 73); bytes.set(b, 2, 70); bytes.set(b, 3, 70)  // "RIFF"
    bytes.set_le32(b, 4, 36 + data_bytes)
    bytes.set(b, 8, 87); bytes.set(b, 9, 65); bytes.set(b, 10, 86); bytes.set(b, 11, 69) // "WAVE"
    // fmt chunk
    bytes.set(b, 12, 102); bytes.set(b, 13, 109); bytes.set(b, 14, 116); bytes.set(b, 15, 32) // "fmt "
    bytes.set_le32(b, 16, 16)            // fmt size
    bytes.set_le16(b, 20, 1)             // PCM
    bytes.set_le16(b, 22, ch)
    bytes.set_le32(b, 24, rate)
    bytes.set_le32(b, 28, rate * ch * 2) // byte rate
    bytes.set_le16(b, 32, ch * 2)        // block align
    bytes.set_le16(b, 34, 16)            // bits per sample
    // data chunk
    bytes.set(b, 36, 100); bytes.set(b, 37, 97); bytes.set(b, 38, 116); bytes.set(b, 39, 97) // "data"
    bytes.set_le32(b, 40, data_bytes)
    // samples (all identical)
    i = 0
    total_samples = frames * ch
    while i < total_samples {
        bytes.set_le16(b, 44 + i * 2, sample16 & 65535)
        i = i + 1
    }
    return bytes.finish(b, total), total
}

main() {
    fails = 0

    if !audio.open() { println("FAIL: open"); exit(1) }
    // The backend is real where a device exists (dev boxes) and null where
    // none does (headless CI) — both are valid; the API behaves identically.
    // Just confirm the query is callable.
    _ = audio.is_null_backend()

    // ---- decode: 8000 frames, stereo, 8000 Hz -> exactly 1000 ms ----
    wav, wlen = make_wav(8000, 2, 8000, 4096)
    src, err = audio.load_wav(wav, wlen)
    fails = fails + ck(err == "", "load ok")
    fails = fails + ck(audio.channels(src) == 2, "2 channels decoded")
    fails = fails + ck(audio.sample_rate(src) == 8000, "8000 Hz decoded")
    fails = fails + ck(audio.duration_ms(src) == 1000, "duration 1000ms (8000 frames @ 8000Hz)")

    // ---- transport ----
    fails = fails + ck(!audio.is_playing(src), "not playing initially")
    fails = fails + ck(audio.position_ms(src) == 0, "position 0 at start")
    fails = fails + ck(audio.play(src), "play returns true")
    fails = fails + ck(audio.is_playing(src), "playing after play")
    fails = fails + ck(audio.pause(src), "pause returns true")
    fails = fails + ck(!audio.is_playing(src), "not playing after pause")

    // ---- seek (clamped) ----
    _ = audio.seek_ms(src, 250)
    fails = fails + ck(audio.position_ms(src) == 250, "seek 250ms")
    _ = audio.seek_ms(src, 999999)   // past end -> clamps to duration
    fails = fails + ck(audio.position_ms(src) == 1000, "seek past end clamps to 1000ms")
    _ = audio.seek_ms(src, -5)       // negative -> clamps to 0
    fails = fails + ck(audio.position_ms(src) == 0, "seek negative clamps to 0")

    // ---- stop rewinds ----
    _ = audio.play(src)
    _ = audio.seek_ms(src, 500)
    _ = audio.stop(src)
    fails = fails + ck(!audio.is_playing(src) && audio.position_ms(src) == 0, "stop halts + rewinds")

    // ---- volume clamp ----
    _ = audio.volume(src, 0.5)
    fails = fails + ck(audio.get_volume(src) == 0.5, "volume 0.5")
    _ = audio.volume(src, 2.0)       // clamps to 1.0
    fails = fails + ck(audio.get_volume(src) == 1.0, "volume clamps high")
    _ = audio.volume(src, -1.0)      // clamps to 0.0
    fails = fails + ck(audio.get_volume(src) == 0.0, "volume clamps low")

    audio.unload(src)

    // ---- error paths ----
    _, e1 = audio.load_wav("not a wav at all!!", 18)
    fails = fails + ck(e1 != "", "garbage rejected")
    _, e2 = audio.load_wav("RIFFxxxxWAVE", 12)   // valid magic, no chunks
    fails = fails + ck(e2 != "", "no fmt/data rejected")

    // ---- mono 44100 duration math ----
    w2, l2 = make_wav(44100, 1, 44100, 0)
    s2, _ = audio.load_wav(w2, l2)
    fails = fails + ck(audio.duration_ms(s2) == 1000, "mono 44100 -> 1000ms")
    fails = fails + ck(audio.channels(s2) == 1, "mono channel count")
    audio.unload(s2)

    audio.close()

    if fails != 0 {
        println("audio: ${fails} failure(s)")
        exit(1)
    }
    println("PASS: test_audio")
}
