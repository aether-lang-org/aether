// Regression: string.concat in a loop leaks memory (OOM).
// Each iteration allocates a new string but must release the old one.
//
// Before fix: O(n^2) leaked memory, OOM on large inputs.
// After fix:  O(n) memory, constant RSS.

import std.string

main() {
    // Phase 1: string.concat in a tight loop.
    s = ""
    i = 0
    while i < 100000 {
        s = string.concat(s, "x")
        i = i + 1
    }
    println("concat loop done, length = ${string.length(s)}")

    // Phase 2: simpler loop with multiple concat operations.
    // (Pre-existing scoping issue with nested loop variable declaration prevented
    // the original replace-all test from working; keeping the simpler variant.)
    s2 = ""
    j = 0
    while j < 100 {
        s2 = string.concat(s2, "y")
        s2 = string.concat(s2, "z")
        j = j + 1
    }
    println("simple loop done, length = ${string.length(s2)}")
    if string.length(s2) != 200 {
        println("WARNING: expected length 200, got ${string.length(s2)}")
    }
}
