// Regression test for std.strbuilder v2 — append_long / append_hex /
// append_codepoint / append_format / finish_with_length / reserve /
// truncate / clear / capacity.
//
// v1 (test_std_strbuilder.ae) covers new/append/append_n/append_byte/
// append_int/length/finish/free. This file exercises only the v2
// surface added for issue #489.
//
// Cases:
//   1.  append_long — 64-bit decimal, positive / negative / large.
//   2.  append_hex  — natural width, zero-pad, and grow-past-width.
//   3.  append_codepoint — 1/2/3/4-byte UTF-8 + invalid rejection.
//   4.  append_format — %d/%s/%x and the >256-byte truncation path.
//   5.  finish_with_length — binary content with embedded NULs.
//   6.  finish_with_length — empty builder yields (non-null, 0).
//   7.  reserve — capacity grows to fit, length unchanged.
//   8.  truncate — shrink, out-of-range rejected, append-after.
//   9.  clear — reset to empty, buffer reused.

import std.strbuilder
import std.string
import std.mem

extern exit(code: int)

main() {
    println("=== std.strbuilder v2 regression ===")

    // Case 1: append_long.
    b1 = strbuilder.new(16)
    strbuilder.append_long(b1, 5000000000)
    strbuilder.append_byte(b1, 124)            // '|'
    strbuilder.append_long(b1, -5000000000)
    strbuilder.append_byte(b1, 124)
    strbuilder.append_long(b1, 9223372036854775807)
    out1 = strbuilder.finish(b1)
    if out1 != "5000000000|-5000000000|9223372036854775807" {
        println("  FAIL 1: got '${out1}'")
        exit(1)
    }
    println("  PASS: append_long")

    // Case 2: append_hex — width 0 (natural), 8 (zero-pad), 2 (grows).
    b2 = strbuilder.new(16)
    strbuilder.append_hex(b2, 255, 0)          // "ff"
    strbuilder.append_byte(b2, 32)             // ' '
    strbuilder.append_hex(b2, 255, 8)          // "000000ff"
    strbuilder.append_byte(b2, 32)
    strbuilder.append_hex(b2, 74565, 2)        // 0x12345 — wider than 2
    out2 = strbuilder.finish(b2)
    if out2 != "ff 000000ff 12345" {
        println("  FAIL 2: got '${out2}'")
        exit(1)
    }
    println("  PASS: append_hex")

    // Case 3: append_codepoint — 1/2/3/4-byte encodings + rejection.
    b3 = strbuilder.new(16)
    r_ascii = strbuilder.append_codepoint(b3, 65)        // 'A'   → 1 byte
    r_2byte = strbuilder.append_codepoint(b3, 0x00F7)    // '÷'   → 2 bytes
    r_3byte = strbuilder.append_codepoint(b3, 0x20AC)    // '€'   → 3 bytes
    r_4byte = strbuilder.append_codepoint(b3, 0x1F600)   // emoji → 4 bytes
    r_surrogate = strbuilder.append_codepoint(b3, 0xD800)   // invalid
    r_toobig    = strbuilder.append_codepoint(b3, 0x110000) // invalid
    if r_ascii != 1 || r_2byte != 1 || r_3byte != 1 || r_4byte != 1 {
        println("  FAIL 3: valid codepoint rejected")
        exit(1)
    }
    if r_surrogate != 0 || r_toobig != 0 {
        println("  FAIL 3: invalid codepoint accepted")
        exit(1)
    }
    // 1 + 2 + 3 + 4 = 10 bytes; the two invalid appends added nothing.
    if strbuilder.length(b3) != 10 {
        println("  FAIL 3: length=${strbuilder.length(b3)}, expected 10")
        exit(1)
    }
    // Byte-exact check via finish_with_length + mem.get_byte —
    // mem.get_byte returns a proper unsigned 0-255, so the high bytes
    // of the multi-byte UTF-8 sequences (0xE2, 0xF0, …) compare
    // cleanly. (string.char_at returns a C `char`, which sign-extends
    // 0x80-0xFF bytes on platforms where `char` is signed.)
    d3, l3 = strbuilder.finish_with_length(b3)
    if l3 != 10 {
        println("  FAIL 3: finished length=${l3}, expected 10")
        exit(1)
    }
    // 'A' at offset 0; ÷ (0x00F7 → C3 B7) at 1-2; € (0x20AC → E2 82
    // AC) at 3-5; emoji (0x1F600 → F0 9F 98 80) at 6-9.
    if mem.get_byte(d3, 0) != 65 {
        println("  FAIL 3: byte 0 not 'A'")
        exit(1)
    }
    if mem.get_byte(d3, 1) != 0xC3 || mem.get_byte(d3, 2) != 0xB7 {
        println("  FAIL 3: division-sign UTF-8 bytes wrong")
        exit(1)
    }
    if mem.get_byte(d3, 3) != 0xE2 || mem.get_byte(d3, 4) != 0x82 ||
       mem.get_byte(d3, 5) != 0xAC {
        println("  FAIL 3: euro UTF-8 bytes wrong")
        exit(1)
    }
    if mem.get_byte(d3, 6) != 0xF0 || mem.get_byte(d3, 7) != 0x9F ||
       mem.get_byte(d3, 8) != 0x98 || mem.get_byte(d3, 9) != 0x80 {
        println("  FAIL 3: emoji UTF-8 bytes wrong")
        exit(1)
    }
    free(d3)
    println("  PASS: append_codepoint")

    // Case 4: append_format — fast path and the >256-byte slow path.
    b4 = strbuilder.new(16)
    strbuilder.append_format(b4, "%d + %d = %d", 2, 3, 5)
    strbuilder.append_byte(b4, 32)
    strbuilder.append_format(b4, "%s/%x", "path", 4042)
    out4 = strbuilder.finish(b4)
    if out4 != "2 + 3 = 5 path/fca" {
        println("  FAIL 4: got '${out4}'")
        exit(1)
    }
    // Slow path: %0300d expands to 300 chars, past the 256-byte scratch.
    b4b = strbuilder.new(8)
    strbuilder.append_format(b4b, "%0300d", 7)
    if strbuilder.length(b4b) != 300 {
        println("  FAIL 4: slow-path length=${strbuilder.length(b4b)}, expected 300")
        exit(1)
    }
    out4b = strbuilder.finish(b4b)
    if string.char_at(out4b, 0) != 48 || string.char_at(out4b, 299) != 55 {
        println("  FAIL 4: slow-path content wrong")
        exit(1)
    }
    println("  PASS: append_format")

    // Case 5: finish_with_length — binary content with an embedded NUL.
    b5 = strbuilder.new(16)
    strbuilder.append_byte(b5, 65)   // 'A'
    strbuilder.append_byte(b5, 0)    // NUL — content, not terminator
    strbuilder.append_byte(b5, 66)   // 'B'
    data5, len5 = strbuilder.finish_with_length(b5)
    if len5 != 3 {
        println("  FAIL 5: length=${len5}, expected 3")
        exit(1)
    }
    if mem.get_byte(data5, 0) != 65 ||
       mem.get_byte(data5, 1) != 0 ||
       mem.get_byte(data5, 2) != 66 {
        println("  FAIL 5: binary bytes wrong")
        exit(1)
    }
    free(data5)
    println("  PASS: finish_with_length binary")

    // Case 6: finish_with_length on an empty builder — non-null, 0.
    b6 = strbuilder.new(8)
    data6, len6 = strbuilder.finish_with_length(b6)
    if len6 != 0 {
        println("  FAIL 6: empty length=${len6}, expected 0")
        exit(1)
    }
    free(data6)
    println("  PASS: finish_with_length empty")

    // Case 7: reserve — capacity grows, length stays 0.
    b7 = strbuilder.new(8)
    cap_before = strbuilder.capacity(b7)
    strbuilder.reserve(b7, 4096)
    cap_after = strbuilder.capacity(b7)
    if cap_after < 4096 {
        println("  FAIL 7: capacity=${cap_after} after reserve(4096)")
        exit(1)
    }
    if strbuilder.length(b7) != 0 {
        println("  FAIL 7: reserve changed length to ${strbuilder.length(b7)}")
        exit(1)
    }
    if cap_before > cap_after {
        println("  FAIL 7: capacity shrank")
        exit(1)
    }
    strbuilder.free(b7)
    println("  PASS: reserve")

    // Case 8: truncate — shrink, reject out-of-range, append-after.
    b8 = strbuilder.new(16)
    strbuilder.append(b8, "hello world")        // length 11
    t_ok = strbuilder.truncate(b8, 5)           // back to "hello"
    if t_ok != 1 || strbuilder.length(b8) != 5 {
        println("  FAIL 8: truncate(5) length=${strbuilder.length(b8)}")
        exit(1)
    }
    t_bad = strbuilder.truncate(b8, 999)        // past length — rejected
    if t_bad != 0 || strbuilder.length(b8) != 5 {
        println("  FAIL 8: out-of-range truncate not rejected")
        exit(1)
    }
    strbuilder.append(b8, "!")
    out8 = strbuilder.finish(b8)
    if out8 != "hello!" {
        println("  FAIL 8: got '${out8}'")
        exit(1)
    }
    println("  PASS: truncate")

    // Case 9: clear — reset to empty, buffer reused for the next build.
    b9 = strbuilder.new(16)
    strbuilder.append(b9, "discarded content")
    strbuilder.clear(b9)
    if strbuilder.length(b9) != 0 {
        println("  FAIL 9: length=${strbuilder.length(b9)} after clear")
        exit(1)
    }
    strbuilder.append(b9, "fresh")
    out9 = strbuilder.finish(b9)
    if out9 != "fresh" {
        println("  FAIL 9: got '${out9}'")
        exit(1)
    }
    println("  PASS: clear")

    println("=== all std.strbuilder v2 cases passed ===")
}
