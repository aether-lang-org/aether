// Regression: issue #480 — distinct types (zero-cost nominal wrappers).
// `type Name = distinct Base` creates a nominally separate type that lowers to
// Base's C type (no boxing). Values cross the boundary only via an explicit
// `as` cast: `x as USD` wraps, `usd as float` unwraps. The compiler refuses
// cross-assignment / cross-call without a cast — those rejections are in the
// negative integration test; here we verify the allowed shapes compile + run.

import std.string
extern exit(code: int)

type USD = distinct float
type Fd  = distinct int

add(a: USD, b: USD) -> USD { return (a as float + b as float) as USD }
fd_value(f: Fd) -> int { return f as int }

main() {
    x = 3.0 as USD
    y = 2.0 as USD
    sum = add(x, y)                 // USD + USD via unwrap/rewrap
    if (sum as float) != 5.0 {
        println("FAIL #480: USD wrap/unwrap arithmetic")
        exit(1)
    }
    fd = 7 as Fd                    // wrap an int into a capability-token type
    if fd_value(fd) != 7 {
        println("FAIL #480: Fd unwrap at call boundary")
        exit(1)
    }
    println("PASS: #480 distinct types — wrap/unwrap, arithmetic, boundaries")
}
