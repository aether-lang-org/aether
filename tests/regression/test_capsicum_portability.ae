// Regression: std.capsicum / std.casper portability contract (the
// graceful-degrade behaviour every downstream — notably aeo's
// require_capsicum() / prefer_capsicum() gates — depends on).
//
// This test runs on EVERY CI platform. It asserts the cross-platform
// contract, branching on os.platform():
//
//   off FreeBSD (linux / macOS / windows / wasm):
//     capsicum.available()  == 0
//     capsicum.in_mode()    == CAP_UNSUPPORTED (-2)
//     capsicum.enter()      == CAP_UNSUPPORTED (-2)   (does NOT crash)
//     capsicum.rights_limit(-1, R_READ) == CAP_UNSUPPORTED
//     casper.available()    == 0
//
//   on FreeBSD:
//     capsicum.available()  == 1   (kernel has Capsicum)
//     capsicum.in_mode()    is 0 or 1 (NOT -2 — the path is live)
//
// The real Capsicum *enforcement* behaviour (entering capability mode,
// Casper delegation) is exercised by the FreeBSD-only tests under
// tests/freebsd/ and the nightly harness — those can't run in the
// current CI matrix (no FreeBSD runner), so this file is the portable
// guard that DOES run everywhere.

import std.capsicum
import std.casper
import std.os
import std.string

main() {
    print("=== std.capsicum / std.casper portability ===\n")
    fails = 0
    plat = os.platform()
    print("platform: ${plat}\n")

    if string.equals(plat, "freebsd") == 1 {
        // FreeBSD: enforcement path is live.
        if capsicum.available() != 1 {
            print("FAIL freebsd: available() != 1 (kernel lacks Capsicum?)\n"); fails = fails + 1 }
        m = capsicum.in_mode()
        if m == capsicum.CAP_UNSUPPORTED {
            print("FAIL freebsd: in_mode() returned CAP_UNSUPPORTED\n"); fails = fails + 1 }
        if m != 0 { if m != 1 {
            print("FAIL freebsd: in_mode() not 0/1: ${m}\n"); fails = fails + 1 } }
        if casper.available() != 1 {
            print("FAIL freebsd: casper.available() != 1\n"); fails = fails + 1 }
    } else {
        // Everywhere else: degrade cleanly, never crash.
        if capsicum.available() != 0 {
            print("FAIL ${plat}: available() != 0\n"); fails = fails + 1 }
        if capsicum.in_mode() != capsicum.CAP_UNSUPPORTED {
            print("FAIL ${plat}: in_mode() != CAP_UNSUPPORTED\n"); fails = fails + 1 }
        if capsicum.enter() != capsicum.CAP_UNSUPPORTED {
            print("FAIL ${plat}: enter() != CAP_UNSUPPORTED\n"); fails = fails + 1 }
        if capsicum.rights_limit(-1, capsicum.R_READ) != capsicum.CAP_UNSUPPORTED {
            print("FAIL ${plat}: rights_limit() != CAP_UNSUPPORTED\n"); fails = fails + 1 }
        if capsicum.fcntls_limit(-1, capsicum.F_GETFL) != capsicum.CAP_UNSUPPORTED {
            print("FAIL ${plat}: fcntls_limit() != CAP_UNSUPPORTED\n"); fails = fails + 1 }
        if casper.available() != 0 {
            print("FAIL ${plat}: casper.available() != 0\n"); fails = fails + 1 }
    }

    // Constant sanity (compile-time wiring of the R_*/F_* bits + codes).
    if capsicum.CAP_UNSUPPORTED != -2 { print("FAIL CAP_UNSUPPORTED const\n"); fails = fails + 1 }
    if capsicum.CAP_OK != 0 { print("FAIL CAP_OK const\n"); fails = fails + 1 }
    if (capsicum.R_READ | capsicum.R_WRITE) != 0x0003 { print("FAIL R_* bits\n"); fails = fails + 1 }

    if fails == 0 {
        print("PASS: std.capsicum / std.casper portability\n")
    } else {
        print("FAILED: ${fails}\n")
        exit(1)
    }
}
