// Regression test for #631 (HMAC-SHA256 + MD5) and #637 (MD4 + binary
// digest output). Verifies the new wrappers in std.cryptography:
//   - md4_hex / md4_bytes (#637)
//   - md5_hex / md5_bytes (#631)
//   - sha1_bytes / sha256_bytes (binary digest output, #637)
//   - hmac_sha256_hex / hmac_sha256_bytes (#631)
//
// Test vectors:
//   - MD4 of "" = 31d6cfe0d16ae931b73c59d7e0c089c0 (RFC 1320 A.5)
//   - MD5 of "" = d41d8cd98f00b204e9800998ecf8427e (RFC 1321 A.5)
//   - SHA-1 of "abc" = a9993e364706816aba3e25717850c26c9cd0d89d (RFC 3174)
//   - SHA-256 of "abc" = ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
//   - HMAC-SHA-256(key="key", msg="The quick brown fox jumps over the lazy dog") =
//       f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8
//     (canonical test vector reproduced in every HMAC-SHA-256 implementation)

import std.cryptography
import std.string

main() {
    print("=== std.cryptography HMAC + MD4 + MD5 + bytes ===\n\n")

    // MD4 of empty string
    md4, e1 = cryptography.md4_hex("", 0)
    if e1 != "" {
        print("SKIP: md4 unavailable (${e1})\n")
        return
    }
    if string.equals(md4, "31d6cfe0d16ae931b73c59d7e0c089c0") != 1 {
        print("FAIL: md4(\"\")=${md4}\n")
        exit(1)
    }
    print("PASS: md4(\"\")\n")

    // MD5 of empty string
    md5, e2 = cryptography.md5_hex("", 0)
    if e2 != "" || string.equals(md5, "d41d8cd98f00b204e9800998ecf8427e") != 1 {
        print("FAIL: md5(\"\")=${md5}\n")
        exit(1)
    }
    print("PASS: md5(\"\")\n")

    // SHA-1 binary digest of "abc" (20 bytes)
    sha1b, len1, e3 = cryptography.sha1_bytes("abc", 3)
    if e3 != "" || len1 != 20 {
        print("FAIL: sha1_bytes len=${len1}\n")
        exit(1)
    }
    print("PASS: sha1_bytes(\"abc\") -> 20 bytes\n")

    // SHA-256 binary digest of "abc" (32 bytes)
    sha256b, len2, e4 = cryptography.sha256_bytes("abc", 3)
    if e4 != "" || len2 != 32 {
        print("FAIL: sha256_bytes len=${len2}\n")
        exit(1)
    }
    print("PASS: sha256_bytes(\"abc\") -> 32 bytes\n")

    // HMAC-SHA-256 hex — canonical test vector.
    msg = "The quick brown fox jumps over the lazy dog"
    msg_len = string_length(msg)
    hmac, e5 = cryptography.hmac_sha256_hex("key", 3, msg, msg_len)
    if e5 != "" {
        print("FAIL: hmac err=${e5}\n")
        exit(1)
    }
    expected = "f7bc83f430538424b13298e6aa6fb143ef4d59a14946175997479dbc2d1a3cd8"
    if string.equals(hmac, expected) != 1 {
        print("FAIL: hmac=${hmac}\n")
        print("      expect=${expected}\n")
        exit(1)
    }
    print("PASS: hmac_sha256_hex(\"key\", fox)\n")

    // HMAC-SHA-256 bytes returns 32 raw bytes.
    hmacb, hlen, e6 = cryptography.hmac_sha256_bytes("key", 3, msg, msg_len)
    if e6 != "" || hlen != 32 {
        print("FAIL: hmac_bytes hlen=${hlen}\n")
        exit(1)
    }
    print("PASS: hmac_sha256_bytes -> 32 bytes\n")

    print("\nAll PASS\n")
}
