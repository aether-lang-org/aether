// Regression: issue #481 — per-function effect tags (`@pure` / `@no_fs` /
// `@no_net` / `@no_os`). A tagged function must not transitively reach the
// forbidden capability; the violations are compile errors covered by the
// negative integration test. Here we verify the allowed shapes compile and
// run: capability-free functions carrying the tags, including a transitive
// call between two pure functions.

import std.string
extern exit(code: int)

@pure
double_label(n: int) -> string {
    return string.concat("n=", string.from_int(n * 2))
}

// Transitive: a @pure function calling another (pure) user function is fine.
@pure
wrapped(n: int) -> string {
    return double_label(n)
}

// Granular tag: this does no filesystem work, so `@no_fs` holds.
@no_fs
classify(n: int) -> int {
    if n > 0 { return 1 }
    return 0
}

main() {
    if wrapped(3) != "n=6" {
        println("FAIL #481: @pure transitive call")
        exit(1)
    }
    if classify(7) != 1 {
        println("FAIL #481: @no_fs function")
        exit(1)
    }
    println("PASS: #481 effect tags hold for capability-free functions")
}
