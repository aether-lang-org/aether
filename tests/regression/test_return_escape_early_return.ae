// Uniform-heap return-escape contract — early return before the
// "final" heap assignment (the Cython-style CWE-401 surface). Every
// return path must route through the shim, including those that
// fire before the heap-tracked local would be updated.

import std.string

extern exit(code: int)

maybe_concat(cond: int, a: string, b: string) -> string {
    if cond == 0 {
        return "fast-path"            // Early return — literal
    }
    if cond == 1 {
        return string.concat(a, b)    // Mid return — heap
    }
    if cond == 2 {
        return a                       // Bare-param return (borrow; non-heap class)
    }
    // Final return — also literal
    return "default"
}

main() {
    println("=== test_return_escape_early_return ===")

    j = 0
    while j < 5000 {
        // Cycle through all four branches
        k = j % 4
        s = maybe_concat(k, "hello-", "world")
        l = string.length(s)
        if l < 1 {
            println("FAIL iter ${j}: branch=${k}, length=${l}")
            exit(1)
        }
        j = j + 1
    }
    println("  PASS: 5000 iterations cycling 4 return branches stable")
    println("=== all cases passed ===")
}
