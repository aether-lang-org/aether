// Regression test for string leak when reassigning with user-defined
// function that returns a heap string.
//
// Bug: `s = my_concat(s, x)` where my_concat returns string did not emit
// the release wrapper. The compiler only recognised hardcoded stdlib
// functions (string_concat, string_substring, etc) and string interpolation
// as heap-returning. Any other function-call RHS was treated as non-heap,
// skipping the `if (_heap_s) free(old_s)` release wrapper.
//
// Fix: Check expr->node_type == TYPE_STRING for function calls, rather than
// just hardcoded function names. Also expanded the hardcoded list to include
// string_copy, string_from_int, string_repeat.
//
// This test verifies that user-defined string-returning functions DO emit
// the release wrapper by checking that reassignment in a loop doesn't leak.

import std.string

extern exit(code: int)

// User-defined helper that returns a fresh string
my_concat(a: string, b: string) -> string {
    return string.concat(a, b)
}

// Another variant that uses string.from_int
my_from_int(n: int) -> string {
    return string.from_int(n)
}

main() {
    // Test 1: User-function reassignment in loop — should NOT leak.
    // If the fix works, this completes quickly with bounded memory.
    // If the fix doesn't work, this leaks every intermediate string.
    s = ""
    i = 0
    while i < 10000 {
        s = my_concat(s, "x")
        i = i + 1
    }
    final_len = string.length(s)
    if final_len != 10000 {
        println("FAIL: Test 1 — final length = ${final_len}, expected 10000")
        exit(1)
    }

    // Test 2: Direct string.concat still works (already had the wrapper).
    s2 = ""
    i2 = 0
    while i2 < 1000 {
        s2 = string.concat(s2, "y")
        i2 = i2 + 1
    }
    if string.length(s2) != 1000 {
        println("FAIL: Test 2 — direct concat length = ${string.length(s2)}, expected 1000")
        exit(1)
    }

    // Test 3: Multiple different string-returning functions
    // (tests the expanded hardcoded list fallback).
    s3 = ""
    i3 = 0
    while i3 < 100 {
        // Variant A: string.from_int (now in expanded hardcoded list)
        temp = string.from_int(i3)
        s3 = string.concat(s3, temp)
        i3 = i3 + 1
    }
    if string.length(s3) < 100 {
        println("FAIL: Test 3 — concat with from_int, length = ${string.length(s3)}, expected >= 100")
        exit(1)
    }

    // Test 4: Reassignment with identifier (transfer ownership).
    // Previously: `sorted = new_sorted` where new_sorted is heap would leak old sorted.
    // This tests the case where the RHS is a variable, not a function call.
    // The fix doesn't address identifier-RHS directly, but the node_type check
    // makes heap tracking more reliable. This is a known limitation documented
    // in the bug report.
    s4 = ""
    i4 = 0
    while i4 < 100 {
        // Build a new string in a separate variable
        new_s4 = string.concat(s4, "z")
        s4 = new_s4
        i4 = i4 + 1
    }
    if string.length(s4) != 100 {
        println("FAIL: Test 4 — identifier reassignment, length = ${string.length(s4)}, expected 100")
        exit(1)
    }

    println("OK")
}
