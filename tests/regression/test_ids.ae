// Regression test for the std identifier modules added alongside #630:
// uuid (v4 + v7), ulid, nanoid, ksuid, tsid.
//
// Shape-only checks. Format correctness (version + variant bits,
// alphabet correctness, length) is what's verifiable here; the
// underlying CSPRNG quality is covered by test_crypto_random_bytes.

import std.uuid
import std.ulid
import std.nanoid
import std.ksuid
import std.tsid
import std.string

main() {
    print("=== std identifier modules ===\n\n")

    // UUIDv4: 36 chars, version nibble at pos 14 = '4', variant nibble
    // at pos 19 in {8,9,a,b}.
    v4, ev4 = uuid.v4()
    if ev4 != "" {
        print("FAIL: uuid.v4 err=${ev4}\n")
        exit(1)
    }
    if string_length(v4) != 36 {
        print("FAIL: v4 length=${v4}\n")
        exit(1)
    }
    ver4 = string.char_at_n(v4, 36, 14)
    if ver4 != 52 {  // '4' = 52
        print("FAIL: v4 version nibble=${ver4}\n")
        exit(1)
    }
    var4 = string.char_at_n(v4, 36, 19)
    // {8,9,a,b} = {56,57,97,98}
    if var4 != 56 && var4 != 57 && var4 != 97 && var4 != 98 {
        print("FAIL: v4 variant=${var4}\n")
        exit(1)
    }
    print("PASS: uuid.v4 = ${v4}\n")

    // UUIDv7: 36 chars, version nibble at pos 14 = '7'.
    v7, ev7 = uuid.v7()
    if ev7 != "" || string_length(v7) != 36 {
        print("FAIL: uuid.v7 err=${ev7}\n")
        exit(1)
    }
    ver7 = string.char_at_n(v7, 36, 14)
    if ver7 != 55 {  // '7' = 55
        print("FAIL: v7 version nibble=${ver7}\n")
        exit(1)
    }
    print("PASS: uuid.v7 = ${v7}\n")

    // ULID: 26 chars Crockford base32. Each char must be in the
    // Crockford set "0123456789ABCDEFGHJKMNPQRSTVWXYZ" (no I, L, O, U).
    u, eu = ulid.generate()
    if eu != "" || string_length(u) != 26 {
        print("FAIL: ulid err=${eu} len=${string_length(u)}\n")
        exit(1)
    }
    crockford = "0123456789ABCDEFGHJKMNPQRSTVWXYZ"
    i = 0
    while i < 26 {
        c = string.char_at_n(u, 26, i)
        // Linear scan in Crockford alphabet.
        found = -1
        j = 0
        while j < 32 {
            if string.char_at_n(crockford, 32, j) == c {
                found = j
                j = 32
            } else {
                j = j + 1
            }
        }
        if found < 0 {
            print("FAIL: ulid char ${c} not in alphabet\n")
            exit(1)
        }
        i = i + 1
    }
    print("PASS: ulid = ${u}\n")

    // NanoID: 21 chars in alphabet [A-Za-z0-9_-].
    nid, eni = nanoid.generate()
    if eni != "" || string_length(nid) != 21 {
        print("FAIL: nanoid err=${eni} len=${string_length(nid)}\n")
        exit(1)
    }
    print("PASS: nanoid = ${nid}\n")

    // KSUID: 27 chars base62 [A-Za-z0-9].
    ks, eks = ksuid.generate()
    if eks != "" || string_length(ks) != 27 {
        print("FAIL: ksuid err=${eks} len=${string_length(ks)}\n")
        exit(1)
    }
    print("PASS: ksuid = ${ks}\n")

    // TSID: 13 chars Crockford base32.
    t, et = tsid.generate()
    if et != "" || string_length(t) != 13 {
        print("FAIL: tsid err=${et} len=${string_length(t)}\n")
        exit(1)
    }
    print("PASS: tsid = ${t}\n")

    print("\nAll PASS\n")
}
