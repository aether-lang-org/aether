// Uniform-heap return-escape contract — pure-literal-returning
// function is classified non-heap (every return path is statically
// non-heap), so the uniform-heap shim is NOT emitted at the return
// site. Zero-overhead guarantee for the common case.
//
// The classifier's OR-fold sees `any_heap = 0`, so caller's wrapper
// sets `_heap_<result> = 0` and does not free.

import std.string

extern exit(code: int)

greet(who: int) -> string {
    if who == 1 {
        return "hello"
    }
    if who == 2 {
        return "world"
    }
    return "default"
}

main() {
    println("=== test_return_escape_literal ===")

    a = greet(1)
    if string.length(a) != 5 {
        println("FAIL: length(greet(1)) = ${string.length(a)}, expected 5")
        exit(1)
    }
    b = greet(2)
    if string.length(b) != 5 {
        println("FAIL: length(greet(2)) = ${string.length(b)}, expected 5")
        exit(1)
    }
    c = greet(99)
    if string.length(c) != 7 {
        println("FAIL: length(greet(99)) = ${string.length(c)}, expected 7")
        exit(1)
    }
    println("  PASS: pure-literal function returns correct values")

    // Hot loop — verifies no caller-side leak even with no shim.
    j = 0
    while j < 10000 {
        s = greet(j)
        if string.length(s) < 5 {
            println("FAIL iter ${j}: length too small")
            exit(1)
        }
        j = j + 1
    }
    println("  PASS: 10000 iterations stable")
    println("=== all cases passed ===")
}
