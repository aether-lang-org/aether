// Regression test (A6, 2026-05-20): a tuple-returning module function
// whose source name is a strict prefix of trailing-underscore sibling
// helpers must remain visible to consumers and tuple-destructurable
// at the call site.
//
// The avn-port report attributed an E0301 failure to a prefix-collision
// in --emit=lib's export filter. The bug did not reproduce on 0.175.0
// — the consumer's typecheck reads the imported .ae source directly,
// so the lib export table's intentional tuple-ABI exclusion never
// affects intra-Aether resolution. This test locks in that decoupling
// so a future regression in cross-module function resolution is caught.

import std.string
import textops

main() {
    merged, st = textops.merge("base", 4, "ours", 4, "theirs", 6)
    if st != 1 {
        println("FAIL: expected status 1, got something else")
    } else {
        println("PASS: merge returned status 1 as expected")
    }
    if string.equals(merged, "ours") == 1 {
        println("PASS: merge returned ours as expected")
    } else {
        println("FAIL: merge first value mismatch")
    }
}
