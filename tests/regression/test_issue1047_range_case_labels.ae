// Regression for #1047: ranged and comma-listed match/switch labels.

extern exit(code: int)

grade(score: int) -> int {
    r = match score {
        90..=100 -> 4
        80..<90  -> 3
        70..<80, 65 -> 2
        _        -> 1
    }
    return r
}

digit_kind(n: int) -> int {
    r = match n {
        0, 2, 4, 6, 8 -> 2
        1, 3, 5, 7, 9 -> 1
        10..<20       -> 10
        _             -> 0
    }
    return r
}

word_kind(s: string) -> int {
    r = match s {
        "y", "yes" -> 1
        "n", "no"  -> 0
        _          -> -1
    }
    return r
}

bucket(x: int) -> int {
    int r = 0
    switch x {
        case 1, 3, 5:
            r = 10
        case 10..<20:
            r = 20
        case 20..=25, 30:
            r = 30
        default:
            r = 99
    }
    return r
}

main() {
    println("=== test_issue1047_range_case_labels ===")

    if grade(100) != 4 { println("FAIL: grade 100"); exit(1) }
    if grade(90) != 4 { println("FAIL: grade 90"); exit(1) }
    if grade(89) != 3 { println("FAIL: grade 89"); exit(1) }
    if grade(80) != 3 { println("FAIL: grade 80"); exit(1) }
    if grade(79) != 2 { println("FAIL: grade 79"); exit(1) }
    if grade(65) != 2 { println("FAIL: grade 65"); exit(1) }
    if grade(64) != 1 { println("FAIL: grade default"); exit(1) }

    if digit_kind(8) != 2 { println("FAIL: even list"); exit(1) }
    if digit_kind(7) != 1 { println("FAIL: odd list"); exit(1) }
    if digit_kind(10) != 10 { println("FAIL: half-open low"); exit(1) }
    if digit_kind(19) != 10 { println("FAIL: half-open high minus one"); exit(1) }
    if digit_kind(20) != 0 { println("FAIL: half-open excludes high"); exit(1) }

    if word_kind("yes") != 1 { println("FAIL: string list yes"); exit(1) }
    if word_kind("no") != 0 { println("FAIL: string list no"); exit(1) }
    if word_kind("maybe") != -1 { println("FAIL: string list default"); exit(1) }

    if bucket(3) != 10 { println("FAIL: switch list"); exit(1) }
    if bucket(10) != 20 { println("FAIL: switch half-open low"); exit(1) }
    if bucket(19) != 20 { println("FAIL: switch half-open high minus one"); exit(1) }
    if bucket(20) != 30 { println("FAIL: switch inclusive low"); exit(1) }
    if bucket(25) != 30 { println("FAIL: switch inclusive high"); exit(1) }
    if bucket(30) != 30 { println("FAIL: switch mixed literal"); exit(1) }
    if bucket(99) != 99 { println("FAIL: switch default"); exit(1) }

    println("=== test_issue1047_range_case_labels passed ===")
}
