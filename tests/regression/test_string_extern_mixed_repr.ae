// Two-string extern call with mixed string representations.
//
// Bug: string.glob_match("main", h) where h was a heap AetherString
// returned 0 even when h's payload matched "main". Same shape hit
// starts_with / ends_with / split: one literal arg, one heap arg,
// and the predicate disagreed with itself depending on which side
// carried the magic-wrapped representation.
//
// Cause: the call-site #297 auto-unwrap skips `string_*`-prefixed
// externs (presumed string-aware), so each arg arrives in its
// native representation — a magic AetherString* or a plain
// const char*. The C-side implementations of string_glob_match_raw
// (fnmatch on the raw pointer), string_starts_with / _ends_with
// (strlen + memcmp on the prefix), and string_split (strlen on the
// delimiter) all assumed `const char*` and read 16 bytes of struct
// header as the first chars when handed a magic AetherString.
//
// Fix: route the second string arg through str_data / str_len, the
// same magic-aware accessors the first arg already used. Now every
// combination of (lit, heap) × (lit, heap) returns the same result.

import std.string

extern exit(code: int)
extern println(s: string)

_check(label: string, got: int, want: int) {
    if got != want {
        println(string.concat(label, ": FAIL"))
        exit(1)
    }
}

main() {
    println("=== test_string_extern_mixed_repr ===")

    h_main = string.substring("xxmainxx", 2, 6)
    h_abc  = string.substring("xxabcxx", 2, 5)
    h_xyz  = string.substring("xxxyzxx", 2, 5)
    h_dot  = string.substring("xxx.cxx", 2, 5)
    h_glob = string.substring("xxm*nxx", 2, 5)

    // glob_match — the originally-reported case.
    _check("glob lit/lit",   string.glob_match("main", "main"),  1)
    _check("glob heap/lit",  string.glob_match(h_main, "main"),  1)
    _check("glob lit/heap",  string.glob_match("main", h_main),  1)
    _check("glob heap/heap", string.glob_match(h_main, h_main),  1)
    _check("glob lit*/heap", string.glob_match("m*n",   h_main), 1)
    _check("glob heap*/lit", string.glob_match(h_glob,  "main"), 1)
    _check("glob nomatch heap/lit", string.glob_match(h_xyz, "main"), 0)

    // glob_match_pathname — same dispatch path, different flags arg.
    _check("path lit/heap",  string.glob_match_pathname("*.c", h_dot), 1)

    // starts_with — two-string extern where the second arg also went
    // through the raw-`const char*` reader (strlen on the prefix).
    _check("sw  lit/lit",   string.starts_with("abcdef", "abc"), 1)
    _check("sw  heap/lit",  string.starts_with(h_abc, "abc"),    1)
    _check("sw  lit/heap",  string.starts_with("abcdef", h_abc), 1)
    _check("sw  heap/heap", string.starts_with(h_abc, h_abc),    1)
    _check("sw  nomatch lit/heap", string.starts_with("zzzdef", h_abc), 0)

    // ends_with — symmetric to starts_with.
    _check("ew  lit/lit",   string.ends_with("xxabc", "abc"), 1)
    _check("ew  lit/heap",  string.ends_with("xxabc", h_abc), 1)
    _check("ew  heap/lit",  string.ends_with(string.concat("xx", h_abc), "abc"), 1)

    // equals / contains / index_of already routed both args through
    // str_data (verified in their pre-fix bodies), but lock them in
    // here too so a regression in either gets caught.
    _check("eq  lit/heap", string.equals("abc", h_abc), 1)
    _check("ct  lit/heap", string.contains("XabcY", h_abc), 1)
    _check("io  lit/heap", string.index_of("XabcY", h_abc), 1)

    println("=== all cases passed ===")
}
