// Test: std.tcp Go-style tuple wrappers.
// Uses a port that refuses connections to exercise the error path
// without hanging.

import std.tcp

main() {
    sock, err = tcp.connect("127.0.0.1", 1)
    if err == "" {
        println("FAIL: connect to :1 should error")
        exit(1)
    }
    if sock != null {
        tcp.close(sock)
    }
    _, werr = tcp.write_n(null, "A", 1)
    if werr == "" {
        println("FAIL: write_n(null) should error")
        exit(1)
    }
    _, n, rerr = tcp.read_n(null, 16)
    if rerr == "" {
        println("FAIL: read_n(null) should error")
        exit(1)
    }
    if n != 0 {
        println("FAIL: read_n(null) length should be 0")
        exit(1)
    }
    println("tcp tuple wrappers ok")
}
