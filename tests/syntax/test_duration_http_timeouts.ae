import std.http
import std.http.client

main() {
    req = client.request("GET", "http://localhost/")
    if req == null {
        println("FAIL: request")
        exit(1)
    }
    err = client.set_timeout(req, 2500ms)
    client.request_free(req)
    if err != "" {
        println("FAIL: client.set_timeout Duration")
        exit(1)
    }

    srv = http.server_create(0)
    if srv == 0 {
        println("FAIL: server_create")
        exit(1)
    }

    ka = http.server_set_keepalive(srv, 1, 0, 5s)
    if ka != "" {
        println("FAIL: server_set_keepalive Duration")
        exit(1)
    }

    shut = http.server_shutdown_graceful(srv, 100ms)
    if shut != "" && shut != "timeout" {
        println("FAIL: server_shutdown_graceful Duration")
        exit(1)
    }

    http.server_free(srv)
    println("PASS")
}
