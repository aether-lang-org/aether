// Project-local override of `foo`. When this directory comes first
// in the --lib chain, `import foo` resolves to this file and
// foo_origin() returns "lib/" — exactly what you want when a
// vendored module has a bug and you're trying out a local patch
// before pushing it upstream.
exports (foo_origin)

foo_origin() -> string {
    return "lib/ (project-local override)"
}
